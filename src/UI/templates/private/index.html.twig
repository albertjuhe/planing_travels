{% extends 'base.html.twig' %}

{% block title %} · My Travels{% endblock %}

{% block content %}

{# ── Stats (owned only) ── #}
{% set total      = travels|length %}
{% set published  = travels|filter(t => t.status == 20)|length %}
{% set drafts     = travels|filter(t => t.status != 20)|length %}
{% set totalStars = 0 %}
{% for t in travels %}{% set totalStars = totalStars + t.stars %}{% endfor %}

{# ── Page header ── #}
<div class="pa-header">
    <div class="container">
        <div class="pa-header__inner">
            <div class="pa-header__left">
                <div class="pa-header__avatar">{{ app.user.username|slice(0,1)|upper }}</div>
                <div>
                    <h1 class="pa-header__title">My Travels</h1>
                    <p class="pa-header__sub">Hello, <strong>{{ app.user.username }}</strong> — here's your travel dashboard</p>
                </div>
            </div>
            <a href="{{ path('newTravel') }}" class="pa-btn-new">
                <svg viewBox="0 0 14 14" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="7" y1="1" x2="7" y2="13"/><line x1="1" y1="7" x2="13" y2="7"/></svg>
                New Travel
            </a>
        </div>
    </div>
</div>

{# ── Stats bar ── #}
<div class="pa-stats-bar">
    <div class="container">
        <div class="pa-stats">
            <div class="pa-stat">
                <span class="pa-stat__num">{{ total }}</span>
                <span class="pa-stat__lbl">Total</span>
            </div>
            <div class="pa-stat-divider"></div>
            <div class="pa-stat">
                <span class="pa-stat__num pa-stat__num--green">{{ published }}</span>
                <span class="pa-stat__lbl">Published</span>
            </div>
            <div class="pa-stat-divider"></div>
            <div class="pa-stat">
                <span class="pa-stat__num pa-stat__num--amber">{{ drafts }}</span>
                <span class="pa-stat__lbl">Drafts</span>
            </div>
            <div class="pa-stat-divider"></div>
            <div class="pa-stat">
                <span class="pa-stat__num pa-stat__num--blue">{{ totalStars }}</span>
                <span class="pa-stat__lbl">Total Stars</span>
            </div>
        </div>
    </div>
</div>

{# ── Main content ── #}
<div class="pa-body">
    <div class="container">

        {% if travels|length > 0 %}

        {# ── Toolbar ── #}
        <div class="pa-toolbar">
            <p class="pa-toolbar__count">{{ total }} travel{{ total != 1 ? 's' : '' }}</p>
            <div class="pa-toolbar__filters" id="pa-filters">
                <button class="pa-filter is-active" data-filter="all">All</button>
                <button class="pa-filter" data-filter="published">Published</button>
                <button class="pa-filter" data-filter="draft">Drafts</button>
            </div>
        </div>

        {# ── Cards grid ── #}
        <div class="pa-grid" id="pa-grid">
            {% for travel in travels %}
            {% set isPublished = travel.status == 20 %}
            <div class="pa-card" data-status="{{ isPublished ? 'published' : 'draft' }}">

                {# Cover image #}
                <div class="pa-card__cover">
                    {% if travel.photo %}
                        <img src="{{ asset('uploads/travel_photos/' ~ travel.photo) }}"
                             class="pa-card__img" alt="{{ travel.title }}">
                    {% else %}
                        <div class="pa-card__placeholder">
                            <svg viewBox="0 0 40 40" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".4"><circle cx="20" cy="20" r="16"/><path d="M20 4a16 16 0 0 1 0 32M4 20h32M6 12h28M6 28h28"/></svg>
                        </div>
                    {% endif %}

                    {# Status pill #}
                    <span class="pa-card__status {{ isPublished ? 'pa-card__status--published' : 'pa-card__status--draft' }}">
                        {% if isPublished %}
                            <svg viewBox="0 0 8 8" width="6" height="6"><circle cx="4" cy="4" r="4" fill="currentColor"/></svg>
                            Published
                        {% else %}
                            <svg viewBox="0 0 8 8" width="6" height="6"><circle cx="4" cy="4" r="4" fill="currentColor"/></svg>
                            Draft
                        {% endif %}
                    </span>
                </div>

                {# Body #}
                <div class="pa-card__body">
                    <h3 class="pa-card__title">
                        <a href="{{ path('show_travel', {'slug': travel.slug}) }}">{{ travel.title }}</a>
                    </h3>

                    {% if travel.startAt and travel.endAt %}
                    <p class="pa-card__dates">
                        <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor" style="margin-right:4px;opacity:.6"><path d="M11 1v1H5V1H3v1H1v13h14V2h-2V1h-2zm2 12H3V6h10v7z"/></svg>
                        {{ travel.startAt|date("d M Y") }} → {{ travel.endAt|date("d M Y") }}
                    </p>
                    {% endif %}

                    {% if travel.description %}
                    <p class="pa-card__desc">{{ travel.description|truncate(90) }}</p>
                    {% endif %}

                    <div class="pa-card__meta">
                        <span class="pa-card__meta-item">
                            <svg viewBox="0 0 16 16" width="12" height="12" fill="#f39c12"><path d="M8 1l1.8 3.6L14 5.3l-3 2.9.7 4.1L8 10.4l-3.7 1.9.7-4.1-3-2.9 4.2-.7z"/></svg>
                            {{ travel.stars }}
                        </span>
                        <span class="pa-card__meta-item">
                            <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor" opacity=".5"><path d="M8 3C4 3 1 8 1 8s3 5 7 5 7-5 7-5-3-5-7-5zm0 8a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>
                            {{ travel.watch }}
                        </span>
                        {% set sharedCount = travel.sharedusers|length %}
                        {% if sharedCount > 0 %}
                        <span class="pa-card__meta-item pa-card__meta-shared" title="Shared with {{ sharedCount }} user{{ sharedCount > 1 ? 's' : '' }}">
                            <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor"><path d="M12 10a2 2 0 0 0-1.6.8L5.9 8.4a2 2 0 0 0 0-1.8l4.5-2.4A2 2 0 1 0 9.6 2.2L5.1 4.6a2 2 0 1 0 0 5.8l4.5 2.4A2 2 0 1 0 12 10z"/></svg>
                            {{ sharedCount }}
                        </span>
                        {% endif %}
                        {% if travel.updatedAt %}
                        <span class="pa-card__meta-item pa-card__meta-item--muted">
                            Updated {{ travel.updatedAt|date("d M") }}
                        </span>
                        {% endif %}
                    </div>
                </div>

                {# Footer actions #}
                <div class="pa-card__footer">
                    <a href="{{ path('updateTravel', {'slug': travel.slug}) }}" class="pa-card__action pa-card__action--edit">
                        <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M11.7 1.3a1 1 0 0 1 1.4 0l1.6 1.6a1 1 0 0 1 0 1.4L5.5 13.5 1 15l1.5-4.5 9.2-9.2z"/></svg>
                        Edit
                    </a>
                    {% if not isPublished %}
                    <a href="{{ path('publishTravel', {'slug': travel.slug}) }}" class="pa-card__action pa-card__action--publish">
                        <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M8 1l7 14H1L8 1zm0 4v5M8 12v1"/></svg>
                        Publish
                    </a>
                    {% else %}
                    <a href="{{ path('show_travel', {'slug': travel.slug}) }}" class="pa-card__action pa-card__action--view">
                        <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M8 3C4 3 1 8 1 8s3 5 7 5 7-5 7-5-3-5-7-5zm0 8a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>
                        View
                    </a>
                    {% endif %}
                </div>

            </div>
            {% endfor %}
        </div>

        {% else %}

        {# ── Empty state ── #}
        {% if sharedTravels is not defined or sharedTravels|length == 0 %}
        <div class="pa-empty">
            <div class="pa-empty__icon">
                <svg viewBox="0 0 80 80" width="80" height="80" fill="none" stroke="#c5cdd6" stroke-width="2">
                    <circle cx="40" cy="40" r="32"/>
                    <path d="M40 8a32 32 0 0 1 0 64M8 40h64M12 24h56M12 56h56"/>
                </svg>
            </div>
            <h2 class="pa-empty__title">No travels yet</h2>
            <p class="pa-empty__text">Start documenting your adventures.<br>Your first travel is just a click away.</p>
            <a href="{{ path('newTravel') }}" class="pa-btn-new pa-btn-new--lg">
                <svg viewBox="0 0 14 14" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="7" y1="1" x2="7" y2="13"/><line x1="1" y1="7" x2="13" y2="7"/></svg>
                Create your first travel
            </a>
        </div>
        {% endif %}

        {% endif %}

        {# ── Shared with me ── #}
        {% if sharedTravels is defined and sharedTravels|length > 0 %}
        <div class="pa-section-header">
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M12 10a2 2 0 0 0-1.6.8L5.9 8.4a2 2 0 0 0 0-1.8l4.5-2.4A2 2 0 1 0 9.6 2.2L5.1 4.6a2 2 0 1 0 0 5.8l4.5 2.4A2 2 0 1 0 12 10z"/></svg>
            Shared with me
            <span class="pa-section-count">{{ sharedTravels|length }}</span>
        </div>
        <div class="pa-grid">
            {% for travel in sharedTravels %}
            <div class="pa-card pa-card--shared">

                <div class="pa-card__cover">
                    {% if travel.photo %}
                        <img src="{{ asset('uploads/travel_photos/' ~ travel.photo) }}"
                             class="pa-card__img" alt="{{ travel.title }}">
                    {% else %}
                        <div class="pa-card__placeholder"></div>
                    {% endif %}
                    <span class="pa-card__status pa-card__status--shared">
                        <svg viewBox="0 0 16 16" width="10" height="10" fill="currentColor"><path d="M12 10a2 2 0 0 0-1.6.8L5.9 8.4a2 2 0 0 0 0-1.8l4.5-2.4A2 2 0 1 0 9.6 2.2L5.1 4.6a2 2 0 1 0 0 5.8l4.5 2.4A2 2 0 1 0 12 10z"/></svg>
                        Shared
                    </span>
                </div>

                <div class="pa-card__body">
                    <h3 class="pa-card__title">
                        <a href="{{ path('show_travel', {'slug': travel.slug}) }}">{{ travel.title }}</a>
                    </h3>
                    {% if travel.startAt and travel.endAt %}
                    <p class="pa-card__dates">
                        <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor" style="margin-right:4px;opacity:.6"><path d="M11 1v1H5V1H3v1H1v13h14V2h-2V1h-2zm2 12H3V6h10v7z"/></svg>
                        {{ travel.startAt|date("d M Y") }} → {{ travel.endAt|date("d M Y") }}
                    </p>
                    {% endif %}
                    {% if travel.description %}
                    <p class="pa-card__desc">{{ travel.description|truncate(90) }}</p>
                    {% endif %}
                    <p class="pa-card__owner">
                        By <strong>{{ travel.user.firstName }} {{ travel.user.lastName }}</strong>
                    </p>
                </div>

                <div class="pa-card__footer">
                    <a href="{{ path('show_travel', {'slug': travel.slug}) }}" class="pa-card__action pa-card__action--view">
                        <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M8 3C4 3 1 8 1 8s3 5 7 5 7-5 7-5-3-5-7-5zm0 8a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>
                        View
                    </a>
                </div>

            </div>
            {% endfor %}
        </div>
        {% endif %}

    </div>
</div>

{% endblock %}

{% block css %}
{{ parent() }}
<style>
/* ─────────────────────────────────────────
   Header
───────────────────────────────────────── */
.pa-header {
    background: linear-gradient(135deg, #1a2e4a 0%, #2980b9 100%);
    padding: 36px 0 32px;
}
.pa-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
}
.pa-header__left {
    display: flex;
    align-items: center;
    gap: 16px;
}
.pa-header__avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #f39c12;
    color: #fff;
    font-size: 22px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(255,255,255,0.25);
}
.pa-header__title {
    font-size: 26px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 4px;
}
.pa-header__sub {
    font-size: 14px;
    color: rgba(255,255,255,0.75);
    margin: 0;
}
.pa-header__sub strong { color: #fff; }

/* New travel button */
.pa-btn-new {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f39c12;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 24px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
}
.pa-btn-new:hover { background: #e67e22; color: #fff; text-decoration: none; transform: translateY(-1px); }
.pa-btn-new--lg { font-size: 15px; padding: 12px 28px; margin-top: 20px; }

/* ─────────────────────────────────────────
   Stats bar
───────────────────────────────────────── */
.pa-stats-bar {
    background: #fff;
    border-bottom: 1px solid #eaecef;
    padding: 0;
}
.pa-stats {
    display: flex;
    align-items: stretch;
    height: 64px;
}
.pa-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    padding: 0 12px;
}
.pa-stat-divider {
    width: 1px;
    background: #eaecef;
    margin: 12px 0;
}
.pa-stat__num {
    font-size: 22px;
    font-weight: 700;
    color: #2c3e50;
    line-height: 1;
}
.pa-stat__num--green { color: #27ae60; }
.pa-stat__num--amber { color: #f39c12; }
.pa-stat__num--blue  { color: #2980b9; }
.pa-stat__lbl {
    font-size: 11px;
    color: #95a5a6;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-top: 3px;
}

/* ─────────────────────────────────────────
   Body
───────────────────────────────────────── */
.pa-body {
    background: #f4f6f8;
    min-height: calc(100vh - 200px);
    padding: 32px 0 60px;
}

/* ─────────────────────────────────────────
   Toolbar
───────────────────────────────────────── */
.pa-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
}
.pa-toolbar__count {
    font-size: 13px;
    color: #7f8c8d;
    margin: 0;
}
.pa-toolbar__filters {
    display: flex;
    gap: 4px;
    background: #eaecef;
    border-radius: 20px;
    padding: 3px;
}
.pa-filter {
    background: transparent;
    border: none;
    padding: 5px 14px;
    border-radius: 16px;
    font-size: 13px;
    font-weight: 500;
    color: #7f8c8d;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
}
.pa-filter.is-active {
    background: #fff;
    color: #1a2e4a;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
}
.pa-filter:hover:not(.is-active) { color: #2c3e50; }

/* ─────────────────────────────────────────
   Cards grid
───────────────────────────────────────── */
.pa-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 24px;
}

/* ─────────────────────────────────────────
   Card
───────────────────────────────────────── */
.pa-card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07), 0 4px 16px rgba(0,0,0,0.05);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
}
.pa-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 24px rgba(0,0,0,0.12);
}
.pa-card.is-hidden { display: none; }

/* Cover */
.pa-card__cover {
    position: relative;
    height: 152px;
    overflow: hidden;
    flex-shrink: 0;
}
.pa-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
}
.pa-card:hover .pa-card__img { transform: scale(1.04); }
.pa-card__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8f0fe 0%, #d0e8f5 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #90a4ae;
}

/* Status pill */
.pa-card__status {
    position: absolute;
    top: 10px;
    right: 10px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3px;
    backdrop-filter: blur(6px);
}
.pa-card__status--published {
    background: rgba(39,174,96,0.15);
    color: #1e8449;
    border: 1px solid rgba(39,174,96,0.3);
}
.pa-card__status--draft {
    background: rgba(243,156,18,0.15);
    color: #b7770d;
    border: 1px solid rgba(243,156,18,0.3);
}

/* Body */
.pa-card__body {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.pa-card__title {
    font-size: 15px;
    font-weight: 700;
    color: #1a2e4a;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.pa-card__title a { color: inherit; text-decoration: none; }
.pa-card__title a:hover { color: #2980b9; }
.pa-card__dates {
    font-size: 12px;
    color: #7f8c8d;
    margin: 0;
    display: flex;
    align-items: center;
}
.pa-card__desc {
    font-size: 13px;
    color: #636e72;
    margin: 0;
    flex: 1;
    line-height: 1.5;
}
.pa-card__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 4px;
}
.pa-card__meta-item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: #636e72;
}
.pa-card__meta-item--muted {
    margin-left: auto;
    color: #b2bec3;
    font-size: 11px;
}
.pa-card__meta-shared {
    color: #2980b9;
    font-weight: 600;
}

/* Footer */
.pa-card__footer {
    display: flex;
    border-top: 1px solid #f0f2f4;
}
.pa-card__action {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 8px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    border-right: 1px solid #f0f2f4;
}
.pa-card__action:last-child { border-right: none; }
.pa-card__action--edit   { color: #636e72; }
.pa-card__action--edit:hover   { background: #f8f9fa; color: #2c3e50; text-decoration: none; }
.pa-card__action--publish { color: #2980b9; }
.pa-card__action--publish:hover { background: #eaf4fd; color: #1a5276; text-decoration: none; }
.pa-card__action--view   { color: #27ae60; }
.pa-card__action--view:hover   { background: #eafaf1; color: #1e8449; text-decoration: none; }

/* shared card */
.pa-card__status--shared {
    background: rgba(41,128,185,0.15);
    color: #1a5276;
    border: 1px solid rgba(41,128,185,0.3);
}
.pa-card--shared { border: 1.5px solid #d6eaf8; }
.pa-card__owner {
    font-size: 12px;
    color: #7f8c8d;
    margin: 4px 0 0;
}
.pa-card__owner strong { color: #2c3e50; }
.pa-section-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    color: #1a2e4a;
    margin: 36px 0 16px;
}
.pa-section-count {
    background: #2980b9;
    color: #fff;
    border-radius: 10px;
    padding: 1px 8px;
    font-size: 12px;
    font-weight: 600;
}

/* ─────────────────────────────────────────
   Empty state
───────────────────────────────────────── */
.pa-empty {
    text-align: center;
    padding: 80px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
}
.pa-empty__icon { margin-bottom: 24px; }
.pa-empty__title { font-size: 22px; font-weight: 700; color: #2c3e50; margin: 0 0 10px; }
.pa-empty__text  { font-size: 15px; color: #7f8c8d; margin: 0; line-height: 1.6; }

/* ─────────────────────────────────────────
   Responsive
───────────────────────────────────────── */
@media (max-width: 767px) {
    .pa-header__title { font-size: 20px; }
    .pa-stats { height: auto; flex-wrap: wrap; padding: 12px 0; }
    .pa-stat  { flex: 1 1 40%; padding: 10px; }
    .pa-stat-divider { display: none; }
    .pa-grid  { grid-template-columns: 1fr 1fr; gap: 16px; }
}
@media (max-width: 480px) {
    .pa-grid { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block javascript %}
{{ parent() }}
<script>
(function () {
    var filters = document.querySelectorAll('.pa-filter');
    var cards   = document.querySelectorAll('.pa-card');

    filters.forEach(function (btn) {
        btn.addEventListener('click', function () {
            filters.forEach(function (b) { b.classList.remove('is-active'); });
            btn.classList.add('is-active');

            var f = btn.dataset.filter;
            cards.forEach(function (card) {
                if (f === 'all' || card.dataset.status === f) {
                    card.classList.remove('is-hidden');
                } else {
                    card.classList.add('is-hidden');
                }
            });
        });
    });
}());
</script>
{% endblock %}
