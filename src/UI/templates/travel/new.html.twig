{% extends 'base.html.twig' %}

{% block title %} · New Travel{% endblock %}

{% block css %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('css/leaflet@1.7.1/leaflet.css') }}"/>
<link rel="stylesheet" href="{{ asset('css/autocomplete@1.8.3/autocomplete.min.css') }}"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" href="/public/font-awesome-4.3.0/css/font-awesome.min.css"/>
<link rel="stylesheet" href="/public/css/ionicons-2.0.1/css/ionicons.min.css"/>
<link rel="stylesheet" href="/public/css/leaflet.awesome-markers.css">
<style>
/* ─────────────────────────────────────────
   Page shell
───────────────────────────────────────── */
.nt-page {
    background: #f4f6f8;
    min-height: calc(100vh - 64px);
    padding-bottom: 60px;
}

/* ─────────────────────────────────────────
   Header
───────────────────────────────────────── */
.nt-header {
    background: linear-gradient(135deg, #1a2e4a 0%, #2980b9 100%);
    padding: 28px 0 24px;
    margin-bottom: 32px;
}
.nt-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
}
.nt-header__left {
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.nt-back {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: rgba(255,255,255,0.7);
    font-size: 13px;
    text-decoration: none;
    transition: color 0.15s;
}
.nt-back:hover { color: #fff; text-decoration: none; }
.nt-header__title {
    font-size: 24px;
    font-weight: 700;
    color: #fff;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
}

/* ─────────────────────────────────────────
   Flash
───────────────────────────────────────── */
.nt-flash {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #eafaf1;
    border: 1px solid #a9dfbf;
    color: #1e8449;
    border-radius: 8px;
    padding: 11px 16px;
    font-size: 14px;
    margin-bottom: 20px;
}

/* ─────────────────────────────────────────
   Layout: two-column
───────────────────────────────────────── */
.nt-container { padding-top: 0; }
.nt-layout {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 24px;
    align-items: start;
}

/* ─────────────────────────────────────────
   Panels
───────────────────────────────────────── */
.nt-panel {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07), 0 4px 16px rgba(0,0,0,0.05);
    overflow: hidden;
    margin-bottom: 20px;
}
.nt-panel--map { margin-bottom: 0; overflow: visible; }
.nt-panel__head {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 13px 18px;
    background: #f8f9fa;
    border-bottom: 1px solid #eaecef;
    font-size: 13px;
    font-weight: 700;
    color: #2c3e50;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.nt-panel__head--map { justify-content: space-between; }
.nt-panel__body { padding: 20px; }

/* ─────────────────────────────────────────
   Location search
───────────────────────────────────────── */
.nt-search-wrap {
    position: relative;
    z-index: 10000;
    margin-bottom: 20px;
}
.nt-search-wrap input[type="text"] {
    width: 100%;
    padding: 10px 14px 10px 38px;
    font-size: 14px;
    color: #2c3e50;
    background: #fff;
    border: 1.5px solid #dde3ea;
    border-radius: 8px;
    outline: none;
    box-sizing: border-box;
    font-family: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
}
.nt-search-wrap input[type="text"]:focus {
    border-color: #2980b9;
    box-shadow: 0 0 0 3px rgba(41,128,185,0.12);
}
.nt-search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: #b0bec5;
    pointer-events: none;
}
.auto-results-wrapper.auto-is-active { z-index: 99999 !important; }

/* ─────────────────────────────────────────
   Cover photo
───────────────────────────────────────── */
.nt-cover-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 120px;
    border: 2px dashed #dde3ea;
    border-radius: 8px;
    color: #b0bec5;
    font-size: 13px;
    margin-bottom: 14px;
    transition: border-color 0.2s, background 0.2s;
}
.nt-cover-empty.has-preview { display: none; }
.nt-cover-preview {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 14px;
    height: 160px;
    background: #f0f2f4;
    display: none;
}
.nt-cover-preview.has-preview { display: block; }
.nt-cover-preview img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 0.3s;
}
.nt-cover-preview:hover img { transform: scale(1.03); }
.nt-cover-label {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(0,0,0,0.45);
    color: #fff;
    font-size: 11px;
    padding: 5px 10px;
    font-weight: 500;
}
.nt-file-field { display: flex; flex-direction: column; gap: 6px; }
.nt-file-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 14px;
    background: #f4f6f8;
    border: 1.5px solid #dde3ea;
    border-radius: 7px;
    font-size: 13px;
    font-weight: 600;
    color: #2c3e50;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    width: fit-content;
}
.nt-file-btn:hover { background: #eaecef; border-color: #c5cdd6; }
.nt-file-input { display: none; }
.nt-file-hint { font-size: 11px; color: #b0bec5; }

/* ─────────────────────────────────────────
   Form fields
───────────────────────────────────────── */
.nt-fields { display: flex; flex-direction: column; gap: 16px; }
.nt-field { display: flex; flex-direction: column; gap: 5px; }
.nt-field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}
.nt-label {
    font-size: 12px;
    font-weight: 700;
    color: #2c3e50;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    margin: 0;
}
.nt-input,
.nt-textarea {
    width: 100%;
    padding: 9px 12px;
    font-size: 14px;
    color: #2c3e50;
    background: #f8f9fa;
    border: 1.5px solid #dde3ea;
    border-radius: 7px;
    outline: none;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
    font-family: inherit;
}
.nt-input:focus,
.nt-textarea:focus {
    border-color: #2980b9;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(41,128,185,0.12);
}
.nt-textarea { resize: vertical; min-height: 90px; }
.nt-hidden { display: none; }

/* Hide Symfony date selects — replaced by Flatpickr */
.nt-date-widget { display: none; }

/* Flatpickr input */
.nt-datepicker-wrap { position: relative; }
.nt-datepicker-wrap svg {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: #b0bec5;
    pointer-events: none;
}
.nt-datepicker {
    width: 100%;
    padding: 9px 12px 9px 32px;
    font-size: 14px;
    color: #2c3e50;
    background: #f8f9fa;
    border: 1.5px solid #dde3ea;
    border-radius: 7px;
    outline: none;
    box-sizing: border-box;
    font-family: inherit;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
}
.nt-datepicker:focus {
    border-color: #2980b9;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(41,128,185,0.12);
}
.flatpickr-calendar {
    border-radius: 10px !important;
    box-shadow: 0 8px 32px rgba(0,0,0,0.14) !important;
    border: 1px solid #eaecef !important;
    font-family: inherit !important;
}
.flatpickr-day.selected, .flatpickr-day.selected:hover {
    background: #2980b9 !important;
    border-color: #2980b9 !important;
}
.flatpickr-day.inRange {
    background: rgba(41,128,185,0.12) !important;
    border-color: transparent !important;
    box-shadow: none !important;
}

/* ─────────────────────────────────────────
   Actions
───────────────────────────────────────── */
.nt-actions {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    margin-top: 4px;
}
.nt-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 22px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s, color 0.15s, transform 0.1s;
}
.nt-btn:active { transform: scale(0.98); }
.nt-btn--primary { background: #27ae60; color: #fff; }
.nt-btn--primary:hover { background: #219a52; color: #fff; text-decoration: none; }
.nt-btn--ghost {
    background: #f4f6f8;
    color: #636e72;
    border: 1.5px solid #dde3ea;
}
.nt-btn--ghost:hover { background: #eaecef; color: #2c3e50; text-decoration: none; }

/* ─────────────────────────────────────────
   Map
───────────────────────────────────────── */
#map {
    height: 520px;
    width: 100%;
}
.nt-map-reset {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 12px;
    font-size: 12px;
    font-weight: 600;
    background: #fff;
    border: 1.5px solid #dde3ea;
    border-radius: 16px;
    color: #2c3e50;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
}
.nt-map-reset:hover { background: #f4f6f8; border-color: #c5cdd6; }

/* ─────────────────────────────────────────
   Responsive
───────────────────────────────────────── */
@media (max-width: 991px) {
    .nt-layout { grid-template-columns: 1fr; }
    #map { height: 360px; }
}
@media (max-width: 600px) {
    .nt-field-row { grid-template-columns: 1fr; }
    .nt-actions { flex-direction: column; }
    .nt-btn { justify-content: center; }
}
</style>
{% endblock %}

{% block content %}
<div class="nt-page">

    {# ── Header ── #}
    <div class="nt-header">
        <div class="container">
            <div class="nt-header__inner">
                <div class="nt-header__left">
                    <a href="{{ path('main_private') }}" class="nt-back">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3L5 8l5 5"/></svg>
                        My Travels
                    </a>
                    <h1 class="nt-header__title">
                        <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" style="opacity:.8;flex-shrink:0"><path d="M8 1l1.8 3.6L14 5.3l-3 2.9.7 4.1L8 10.4l-3.7 1.9.7-4.1-3-2.9 4.2-.7z"/></svg>
                        New Travel
                    </h1>
                </div>
            </div>
        </div>
    </div>

    {# ── Body ── #}
    <div class="container nt-container">

        {% for flashMessage in app.session.flashbag.get('notice') %}
            <div class="nt-flash">
                <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor"><path d="M8 1a7 7 0 1 1 0 14A7 7 0 0 1 8 1zm3.3 4.3L7 9.6 4.7 7.3l-1 1L7 11.6l5.3-5.3-1-1z"/></svg>
                {{ flashMessage }}
            </div>
        {% endfor %}

        <div class="nt-layout">

            {# ── Left: form ── #}
            <div class="nt-form-col">
                {{ form_start(travelForm, {'attr': {'enctype': 'multipart/form-data', 'id': 'nt-form'}}) }}

                {# Location search #}
                <div class="nt-search-wrap">
                    <svg class="nt-search-icon" viewBox="0 0 16 16" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="6.5" cy="6.5" r="4.5"/><path d="M10.5 10.5L14 14"/></svg>
                    <input type="text" autocomplete="off" id="search" placeholder="Search a location…"/>
                </div>

                {# Cover photo panel #}
                <div class="nt-panel">
                    <div class="nt-panel__head">
                        <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" opacity=".7"><path d="M0 3h16v10H0V3zm1 1v8h14V4H1zm4 2a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm-1 5l2-3 2 2 2-3 3 4H3z"/></svg>
                        Cover Photo
                    </div>
                    <div class="nt-panel__body">
                        <div class="nt-cover-empty" id="nt-cover-empty">
                            <svg viewBox="0 0 48 48" width="40" height="40" fill="none" stroke="#b0bec5" stroke-width="1.5"><rect x="4" y="8" width="40" height="32" rx="3"/><circle cx="16" cy="20" r="4"/><path d="M4 36l10-12 8 8 6-7 12 11"/></svg>
                            <span>No cover yet</span>
                        </div>
                        <div class="nt-cover-preview" id="nt-cover-preview">
                            <img src="" alt="Preview" id="nt-cover-img">
                            <span class="nt-cover-label">New cover (unsaved)</span>
                        </div>
                        <div class="nt-file-field">
                            {{ form_label(travelForm.photo, null, {'label_attr': {'class': 'nt-label'}}) }}
                            <label class="nt-file-btn" for="{{ travelForm.photo.vars.id }}">
                                <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M8 1v9M4 6l4-4 4 4M2 13h12"/></svg>
                                Choose image
                            </label>
                            {{ form_widget(travelForm.photo, {'attr': {'class': 'nt-file-input', 'id': travelForm.photo.vars.id}}) }}
                            <span class="nt-file-hint">JPEG, PNG, WebP · max 5 MB</span>
                            {{ form_errors(travelForm.photo) }}
                        </div>
                    </div>
                </div>

                {# Details panel #}
                <div class="nt-panel">
                    <div class="nt-panel__head">
                        <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" opacity=".7"><path d="M2 2h12v12H2V2zm1 1v10h10V3H3zm2 2h6v1H5V5zm0 3h6v1H5V8zm0 3h4v1H5v-1z"/></svg>
                        Travel Details
                    </div>
                    <div class="nt-panel__body nt-fields">

                        <div class="nt-field">
                            {{ form_label(travelForm.title, 'Title', {'label_attr': {'class': 'nt-label'}}) }}
                            {{ form_widget(travelForm.title, {'attr': {'class': 'nt-input', 'placeholder': 'e.g. Summer in Japan'}}) }}
                            {{ form_errors(travelForm.title) }}
                        </div>

                        <div class="nt-field-row">
                            <div class="nt-field">
                                {{ form_label(travelForm.startAt, 'Start date', {'label_attr': {'class': 'nt-label'}}) }}
                                <div class="nt-datepicker-wrap">
                                    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M11 1v1H5V1H3v1H1v13h14V2h-2V1h-2zm2 12H3V6h10v7z"/></svg>
                                    <input type="text" class="nt-datepicker" id="nt-start-picker" placeholder="Select date" readonly>
                                </div>
                                {{ form_widget(travelForm.startAt, {'attr': {'class': 'nt-date-widget'}}) }}
                                {{ form_errors(travelForm.startAt) }}
                            </div>
                            <div class="nt-field">
                                {{ form_label(travelForm.endAt, 'End date', {'label_attr': {'class': 'nt-label'}}) }}
                                <div class="nt-datepicker-wrap">
                                    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M11 1v1H5V1H3v1H1v13h14V2h-2V1h-2zm2 12H3V6h10v7z"/></svg>
                                    <input type="text" class="nt-datepicker" id="nt-end-picker" placeholder="Select date" readonly>
                                </div>
                                {{ form_widget(travelForm.endAt, {'attr': {'class': 'nt-date-widget'}}) }}
                                {{ form_errors(travelForm.endAt) }}
                            </div>
                        </div>

                        <div class="nt-field">
                            {{ form_label(travelForm.description, 'Description', {'label_attr': {'class': 'nt-label'}}) }}
                            {{ form_widget(travelForm.description, {'attr': {'class': 'nt-textarea', 'rows': '4', 'placeholder': 'Describe your travel experience…'}}) }}
                            {{ form_errors(travelForm.description) }}
                        </div>

                        {# Hidden geo fields #}
                        <div class="nt-hidden">
                            {{ form_row(travelForm.geoLocation) }}
                        </div>

                    </div>
                </div>

                {# Actions #}
                <div class="nt-actions">
                    <a href="{{ path('main_private') }}" class="nt-btn nt-btn--ghost">Cancel</a>
                    <button type="submit" class="nt-btn nt-btn--primary">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M13 2H5L2 5v9h12V2h-1zm-5 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm2-9H5V3h5v1z"/></svg>
                        Save travel
                    </button>
                </div>

                {{ form_end(travelForm) }}
            </div>

            {# ── Right: map ── #}
            <div class="nt-map-col">
                <div class="nt-panel nt-panel--map">
                    <div class="nt-panel__head nt-panel__head--map">
                        <span>
                            <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" opacity=".7"><path d="M8 1a5 5 0 0 1 5 5c0 4-5 9-5 9S3 10 3 6a5 5 0 0 1 5-5zm0 3a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/></svg>
                            Location
                        </span>
                        <button class="nt-map-reset" id="nt-reset" type="button">
                            <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M8 5a3 3 0 1 1 0 6A3 3 0 0 1 8 5zM1 7h2m10 0h2M7 1v2m0 10v2"/></svg>
                            Reset view
                        </button>
                    </div>
                    <div id="map"></div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}

{% block javascript %}
{{ parent() }}
<script src="{{ asset('js/leaflet@1.7.1/leaflet.js') }}"></script>
<script src="{{ asset('js/leaflet.awesome-markers.min.js') }}"></script>
<script src="{{ asset('js/markersDefinition.js') }}"></script>
<script src="{{ asset('js/autocomplete@1.8.3/autocomplete.js') }}"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
(function () {
    /* ── Map ── */
    var defaultLat = 48.8566;
    var defaultLng = 2.3522;

    var map = L.map('map', { center: [defaultLat, defaultLng], zoom: 4 });

    var osm           = L.tileLayer('http://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png');
    var googleTerrain = L.tileLayer('http://{s}.google.com/vt/lyrs=p&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains: ['mt0','mt1','mt2','mt3'] });
    var googleSat     = L.tileLayer('http://{s}.google.com/vt/lyrs=s&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains: ['mt0','mt1','mt2','mt3'] });
    var googleHybrid  = L.tileLayer('http://{s}.google.com/vt/lyrs=s,h&x={x}&y={y}&z={z}', { maxZoom: 20, subdomains: ['mt0','mt1','mt2','mt3'] });
    var googleRoad    = L.tileLayer('http://{s}.google.com/vt/lyrs=m&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains: ['mt0','mt1','mt2','mt3'] }).addTo(map);
    var googleTraffic = L.tileLayer('https://{s}.google.com/vt/lyrs=m@221097413,traffic&x={x}&y={y}&z={z}', { maxZoom: 20, minZoom: 2, subdomains: ['mt0','mt1','mt2','mt3'] });

    map.addControl(new L.Control.Layers({
        'OSM': osm,
        'Google Hybrid': googleHybrid,
        'Google Satellite': googleSat,
        'Google Terrain': googleTerrain,
        'Road Map': googleRoad,
        'Traffic': googleTraffic
    }, {}));

    var currentMarker = null;

    document.getElementById('nt-reset').addEventListener('click', function () {
        map.setView([defaultLat, defaultLng], 4);
    });

    /* ── Flatpickr date pickers ── */
    function writeSelectsDate(fieldId, date) {
        if (!date) return;
        var y = document.getElementById(fieldId + '_year');
        var m = document.getElementById(fieldId + '_month');
        var d = document.getElementById(fieldId + '_day');
        if (!y || !m || !d) return;
        y.value = date.getFullYear();
        m.value = date.getMonth() + 1;
        d.value = date.getDate();
    }

    var startFieldId = '{{ travelForm.startAt.vars.id }}';
    var endFieldId   = '{{ travelForm.endAt.vars.id }}';

    flatpickr('#nt-start-picker', {
        dateFormat: 'd M Y',
        onChange: function(dates) {
            writeSelectsDate(startFieldId, dates[0]);
        }
    });

    flatpickr('#nt-end-picker', {
        dateFormat: 'd M Y',
        onChange: function(dates) {
            writeSelectsDate(endFieldId, dates[0]);
        }
    });

    /* ── Autocomplete ── */
    new Autocomplete('search', {
        selectFirst: true,
        insertToInput: true,
        cache: true,
        howManyCharacters: 2,

        onSearch: function (ref) {
            var currentValue = ref.currentValue;
            var api = 'https://nominatim.openstreetmap.org/search?format=geojson&limit=5&q=' + encodeURIComponent(currentValue);
            return new Promise(function (resolve) {
                fetch(api)
                    .then(function (r) { return r.json(); })
                    .then(function (data) { resolve(data.features); })
                    .catch(function (e) { console.error(e); });
            });
        },

        onResults: function (ref) {
            var currentValue = ref.currentValue;
            var matches = ref.matches;
            var template = ref.template;
            var regex = new RegExp(currentValue, 'gi');
            return matches === 0 ? template : matches.map(function (el) {
                return '<li><p>' + el.properties.display_name.replace(regex, function (s) { return '<b>' + s + '</b>'; }) + '</p></li>';
            }).join('');
        },

        onSubmit: function (ref) {
            var object = ref.object;
            var coords = object.geometry.coordinates;
            var lng = coords[0];
            var lat = coords[1];

            if (currentMarker) { map.removeLayer(currentMarker); }
            currentMarker = L.marker([lat, lng], { icon: centerMarker, title: object.properties.display_name })
                .addTo(map)
                .bindPopup(object.properties.display_name)
                .openPopup();

            document.getElementById('travel_geoLocation_lat').value = lat;
            document.getElementById('travel_geoLocation_lng').value = lng;

            map.setView([lat, lng], 8);
        },

        noResults: function (ref) {
            return ref.template('<li>No results found: "' + ref.currentValue + '"</li>');
        }
    });

    /* ── Live cover preview ── */
    var fileInput = document.querySelector('.nt-file-input');
    if (fileInput) {
        fileInput.addEventListener('change', function () {
            if (!this.files || !this.files[0]) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                var img = document.getElementById('nt-cover-img');
                var preview = document.getElementById('nt-cover-preview');
                var empty   = document.getElementById('nt-cover-empty');
                img.src = e.target.result;
                preview.classList.add('has-preview');
                empty.classList.add('has-preview');
            };
            reader.readAsDataURL(this.files[0]);
        });
    }
}());
</script>
{% endblock %}
