// GPX Tracks
var gpxLayers = {};
{% for gpx in gpxs %}
(function () {
    var idx = {{ loop.index0 }};
    var url = '{{ asset('uploads/gpx/') }}{{ gpx.filename }}';
    var track = new L.GPX(url, {
        async: true,
        marker_options: {
            startIconUrl: '{{ asset('img/pin-icon-start.png') }}',
            endIconUrl: '{{ asset('img/pin-icon-end.png') }}',
            shadowUrl: '{{ asset('img/pin-shadow.png') }}'
        },
        polyline_options: { color: '{{ gpx.color }}' }
    }).on('loaded', function (e) {
        var target = e.target;
        map.fitBounds(target.getBounds());
        gpxLayers[idx] = target;
    }).addTo(map);
})();
{% endfor %}
