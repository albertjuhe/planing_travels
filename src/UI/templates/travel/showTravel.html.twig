{% extends 'old_base.html.twig' %}

{% block title %}Travel {{travel.title }}{% endblock %}

{% block navbar %}
    {% include 'default/navbarPublic.html.twig' %}
{% endblock %}

{% block css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/leaflet@1.7.1/leaflet.css')}}"/>
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.css"/>
    <link rel="stylesheet" href="{{ asset('font-awesome-4.3.0/css/font-awesome.min.css') }}"/>
    <link rel="stylesheet" href="{{ asset('css/ionicons-2.0.1/css/ionicons.min.css') }}"/>
    <link rel="stylesheet" href="{{ asset('css/leaflet.awesome-markers.css')}}"/>
    <link rel="stylesheet" href="{{ asset('css/dropzone.css')}}"/>
    <link rel="stylesheet" href="{{ asset('css/autocomplete@1.8.3/autocomplete.min.css') }}"/>
    <link href='https://api.mapbox.com/mapbox.js/plugins/leaflet-fullscreen/v1.0.1/leaflet.fullscreen.css' rel='stylesheet'/>
    <style>
/* ─────────────────────────────────────────
   Page shell
───────────────────────────────────────── */
.st-page {
    background: #f4f6f8;
    min-height: calc(100vh - 64px);
    padding-bottom: 60px;
}

/* ─────────────────────────────────────────
   Header  (same as pa-header)
───────────────────────────────────────── */
.pa-header {
    background: linear-gradient(135deg, #1a2e4a 0%, #2980b9 100%);
    padding: 36px 0 32px;
}
.pa-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
}
.pa-header__left {
    display: flex;
    align-items: center;
    gap: 16px;
}
.pa-header__icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #f39c12;
    color: #fff;
    font-size: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(255,255,255,0.25);
}
.pa-header__titles { display: flex; flex-direction: column; gap: 4px; }
.pa-header__back {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: rgba(255,255,255,0.6);
    font-size: 12px;
    text-decoration: none;
    transition: color 0.15s;
    margin-bottom: 2px;
}
.pa-header__back:hover { color: #fff; text-decoration: none; }
.pa-header__title {
    font-size: 26px;
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.2;
}
.pa-header__sub {
    font-size: 14px;
    color: rgba(255,255,255,0.75);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
}
.pa-header__sub strong { color: #fff; }
.pa-header__meta-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
}
.pa-header__right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}
.pa-stat-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
}
.pa-btn-new {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f39c12;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 24px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
}
.pa-btn-new:hover { background: #e67e22; color: #fff; text-decoration: none; transform: translateY(-1px); }
.pa-btn-share { background: rgba(255,255,255,0.18); border: 1.5px solid rgba(255,255,255,0.4); }
.pa-btn-share:hover { background: rgba(255,255,255,0.28); color: #fff; }

/* ─── Share modal ─── */
.sh-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 2000;
    align-items: center;
    justify-content: center;
}
.sh-overlay.is-open { display: flex; }
.sh-modal {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.22);
    width: 100%;
    max-width: 420px;
    padding: 28px 28px 24px;
    position: relative;
}
.sh-modal__title {
    font-size: 18px;
    font-weight: 700;
    color: #1a2e4a;
    margin: 0 0 6px;
    display: flex;
    align-items: center;
    gap: 9px;
}
.sh-modal__sub {
    font-size: 13px;
    color: #7f8c8d;
    margin: 0 0 20px;
}
.sh-modal__field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 16px; }
.sh-modal__label { font-size: 12px; font-weight: 700; color: #2c3e50; text-transform: uppercase; letter-spacing: 0.4px; }
.sh-modal__input {
    width: 100%;
    padding: 10px 13px;
    font-size: 14px;
    border: 1.5px solid #dde3ea;
    border-radius: 8px;
    outline: none;
    background: #f8f9fa;
    box-sizing: border-box;
    transition: border-color 0.2s, box-shadow 0.2s;
}
.sh-modal__input:focus { border-color: #2980b9; background: #fff; box-shadow: 0 0 0 3px rgba(41,128,185,0.12); }
.sh-modal__actions { display: flex; gap: 10px; justify-content: flex-end; }
.sh-modal__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 20px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
}
.sh-modal__btn:active { transform: scale(0.97); }
.sh-modal__btn--cancel { background: #f4f6f8; color: #636e72; border: 1.5px solid #dde3ea; }
.sh-modal__btn--cancel:hover { background: #eaecef; color: #2c3e50; }
.sh-modal__btn--submit { background: #2980b9; color: #fff; }
.sh-modal__btn--submit:hover { background: #1e6fa8; }
.sh-modal__btn--submit:disabled { opacity: 0.6; cursor: not-allowed; }
.sh-modal__close {
    position: absolute;
    top: 14px; right: 16px;
    background: none;
    border: none;
    font-size: 20px;
    color: #b0bec5;
    cursor: pointer;
    line-height: 1;
    padding: 2px 6px;
    border-radius: 4px;
    transition: color 0.15s;
}
.sh-modal__close:hover { color: #636e72; }
.sh-modal__feedback {
    font-size: 13px;
    padding: 9px 13px;
    border-radius: 7px;
    margin-bottom: 14px;
    display: none;
}
.sh-modal__users {
    margin-bottom: 16px;
}
.sh-modal__users-title {
    font-size: 12px;
    font-weight: 700;
    color: #2c3e50;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    margin-bottom: 8px;
}
.sh-modal__users-empty {
    font-size: 13px;
    color: #b0bec5;
    padding: 8px 0;
}
.sh-user-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 7px 10px;
    border-radius: 7px;
    background: #f8f9fa;
    border: 1px solid #eaecef;
    margin-bottom: 5px;
    font-size: 13px;
    color: #2c3e50;
}
.sh-user-row__name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sh-user-row__name small { color: #7f8c8d; margin-left: 4px; font-size: 11px; }
.sh-user-revoke {
    flex-shrink: 0;
    background: none;
    border: 1px solid #e74c3c;
    color: #e74c3c;
    border-radius: 5px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
}
.sh-user-revoke:hover { background: #e74c3c; color: #fff; }
.sh-modal__divider {
    border: none;
    border-top: 1px solid #eaecef;
    margin: 14px 0;
}

/* ─────────────────────────────────────────
   Layout - Split view: mapa + localizaciones visibles
───────────────────────────────────────── */
.st-layout {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.st-map-locations {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 0;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08), 0 8px 32px rgba(0,0,0,0.08);
    overflow: hidden;
    height: 500px;
    transition: grid-template-columns 0.3s ease;
}
.st-map-locations.sidebar-collapsed {
    grid-template-columns: 1fr 0px;
}

.st-map-area {
    position: relative;
    display: flex;
    flex-direction: column;
    min-width: 0;
    height: 500px;
}

.st-locations-sidebar {
    display: flex;
    flex-direction: column;
    border-left: 1px solid #eaecef;
    background: #fafbfc;
    overflow: hidden;
    transition: width 0.3s ease, opacity 0.3s ease;
    width: 320px;
    min-width: 0;
    height: 500px;
}
.st-map-locations.sidebar-collapsed .st-locations-sidebar {
    opacity: 0;
    width: 0;
    border-left: none;
}

.st-locations-panel {
    display: flex;
    flex-direction: column;
    height: 100%;
}

.st-locations-sidebar .st-panel__head {
    background: #fff;
    border-bottom: 1px solid #eaecef;
    flex-shrink: 0;
    white-space: nowrap;
}

.st-locations-sidebar #mapPoints {
    overflow-y: auto;
    overflow-x: hidden;
    flex: 1;
    padding: 8px;
}

/* Collapse toggle button on the map header */
.st-sidebar-toggle {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.35);
    background: rgba(255,255,255,0.15);
    color: #fff;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
    letter-spacing: 0.3px;
    text-transform: uppercase;
}
.st-sidebar-toggle:hover { background: rgba(255,255,255,0.25); }
.st-sidebar-toggle__icon {
    transition: transform 0.3s ease;
    flex-shrink: 0;
}
.sidebar-collapsed .st-sidebar-toggle__icon {
    transform: rotate(180deg);
}

.st-details-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
}

.st-sidebar { display: flex; flex-direction: column; gap: 16px; }
.st-main    { display: flex; flex-direction: column; gap: 16px; }

/* ─────────────────────────────────────────
   Panels
───────────────────────────────────────── */
.st-panel {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07), 0 4px 16px rgba(0,0,0,0.05);
    overflow: hidden;
}
.st-panel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 11px 16px;
    background: #f8f9fa;
    border-bottom: 1px solid #eaecef;
    font-size: 12px;
    font-weight: 700;
    color: #2c3e50;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.st-panel__head-left { display: flex; align-items: center; gap: 7px; }
.st-panel__body { padding: 0; }
.st-panel__body--pad { padding: 16px; }

/* ─────────────────────────────────────────
   Panel buttons
───────────────────────────────────────── */
.st-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 12px;
    font-size: 12px;
    font-weight: 600;
    border-radius: 16px;
    border: 1.5px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    white-space: nowrap;
}
.st-btn:active { transform: scale(0.97); }
.st-btn--primary {
    background: #2980b9;
    color: #fff;
    border-color: #2980b9;
}
.st-btn--primary:hover { background: #1e6fa8; border-color: #1e6fa8; color: #fff; text-decoration: none; }
.st-btn--warning {
    background: #f39c12;
    color: #fff;
    border-color: #f39c12;
}
.st-btn--warning:hover { background: #e67e22; border-color: #e67e22; color: #fff; text-decoration: none; }
.st-btn--danger {
    background: #e74c3c;
    color: #fff;
    border-color: #e74c3c;
}
.st-btn--danger:hover { background: #c0392b; border-color: #c0392b; color: #fff; text-decoration: none; }
.st-btn--ghost {
    background: #f4f6f8;
    color: #636e72;
    border-color: #dde3ea;
}
.st-btn--ghost:hover { background: #eaecef; color: #2c3e50; text-decoration: none; }

/* ─────────────────────────────────────────
   Map - Prominente con header integrado
───────────────────────────────────────── */
.st-map-area .st-panel__head {
    background: linear-gradient(135deg, #1a2e4a 0%, #2574a9 100%);
    border-bottom: none;
    color: #fff;
}
.st-map-area .st-panel__head svg {
    opacity: 0.9;
}
#map {
    flex: 1;
    width: 100%;
    display: block;
    min-height: 0;
}

/* ─────────────────────────────────────────
   Locations list
───────────────────────────────────────── */
/* #mapPoints scroll is handled by .st-locations-sidebar flex layout */
#mapPoints::-webkit-scrollbar { width: 5px; }
#mapPoints::-webkit-scrollbar-track { background: #f4f6f8; }
#mapPoints::-webkit-scrollbar-thumb { background: #c5cdd6; border-radius: 3px; }

/* ─────────────────────────────────────────
   Route panel
───────────────────────────────────────── */
#routePoints {
    max-height: 240px;
    overflow-y: auto;
    padding: 8px;
    font-size: 13px;
    color: #636e72;
}
.st-panel-footer {
    display: flex;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid #eaecef;
    background: #f8f9fa;
    flex-wrap: wrap;
}

/* ─────────────────────────────────────────
   Tracks panel
───────────────────────────────────────── */
#tracks {
    max-height: 180px;
    overflow-y: auto;
    padding: 8px;
    font-size: 13px;
    color: #636e72;
}

/* ─────────────────────────────────────────
   Gallery / info panel
───────────────────────────────────────── */
#location_media { display: none; }
#location_media.is-visible { display: block; }

.st-gallery-title {
    font-size: 13px;
    font-weight: 600;
    color: #2c3e50;
}
#dz-ImageLocation {
    min-height: 80px;
}
.st-notes-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    color: #7f8c8d;
    margin-bottom: 6px;
}
#notes {
    font-size: 13px;
    color: #2c3e50;
    line-height: 1.6;
}

/* ─────────────────────────────────────────
   Point card (injected by JS)
───────────────────────────────────────── */
.point-view {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid #eaecef;
    margin-bottom: 6px;
    cursor: move;
    background: #fff;
    transition: border-color 0.15s, box-shadow 0.15s;
}
.point-view:hover {
    border-color: #c5cdd6;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.address-point { font-size: 12px; color: #7f8c8d; }
.title-point   { font-size: 13px; font-weight: 600; color: #2c3e50; }
.sortable-placeholder {
    border: 2px dashed #c5cdd6;
    border-radius: 8px;
    background: #f8f9fa;
    height: 44px;
    margin-bottom: 6px;
}

/* ─────────────────────────────────────────
   Info notification
───────────────────────────────────────── */
#infoTravel {
    margin-bottom: 16px;
}
#panel-information {
    font-size: 12px;
    color: rgba(255,255,255,0.6);
}

/* ─────────────────────────────────────────
   View tabs (Map / Calendar)
───────────────────────────────────────── */
.st-view-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
    margin-top: 20px;
}
.st-view-tab {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 20px;
    font-size: 13px;
    font-weight: 600;
    border-radius: 20px;
    border: 1.5px solid #dde3ea;
    background: #fff;
    color: #636e72;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.st-view-tab:hover { background: #f4f6f8; color: #2c3e50; }
.st-view-tab.is-active {
    background: #2980b9;
    color: #fff;
    border-color: #2980b9;
}
.st-view-panel { display: none; }
.st-view-panel.is-active { display: block; }

/* ─────────────────────────────────────────
   Calendar view
───────────────────────────────────────── */
.cal-wrap {
    display: flex;
    gap: 16px;
    align-items: flex-start;
}

/* ── Unscheduled sidebar ── */
.cal-unscheduled {
    flex-shrink: 0;
    width: 200px;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07), 0 4px 16px rgba(0,0,0,0.05);
    overflow: hidden;
    position: sticky;
    top: 16px;
}
.cal-unscheduled__head {
    padding: 11px 14px;
    background: #f8f9fa;
    border-bottom: 1px solid #eaecef;
    font-size: 11px;
    font-weight: 700;
    color: #7f8c8d;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.cal-unscheduled__body {
    padding: 8px;
    min-height: 60px;
    max-height: 420px;
    overflow-y: auto;
}
.cal-unscheduled__empty {
    font-size: 12px;
    color: #b0bec5;
    text-align: center;
    padding: 16px 8px;
}

/* ── Calendar grid (week view) ── */
.cal-main {
    flex: 1;
    min-width: 0;
}
.cal-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
}
.cal-nav__label {
    font-size: 14px;
    font-weight: 700;
    color: #1a2e4a;
}
.cal-nav__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid #dde3ea;
    background: #fff;
    color: #636e72;
    cursor: pointer;
    font-size: 14px;
    transition: background 0.15s, color 0.15s;
}
.cal-nav__btn:hover { background: #2980b9; color: #fff; border-color: #2980b9; }
.cal-nav__btn:disabled { opacity: 0.35; cursor: default; pointer-events: none; }
.cal-grid {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07), 0 4px 16px rgba(0,0,0,0.05);
    overflow: hidden;
}
.cal-grid__header {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    border-bottom: 2px solid #eaecef;
}
.cal-grid__dow {
    padding: 8px 4px;
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    color: #95a5a6;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.cal-grid__body {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
}
.cal-grid__body .cal-day { display: none; }
.cal-day {
    border-right: 1px solid #f0f2f4;
    border-bottom: 1px solid #f0f2f4;
    min-height: 120px;
    display: flex;
    flex-direction: column;
}
.cal-day:nth-child(7n) { border-right: none; }
.cal-day--out { background: #fafbfc; }
.cal-day__head {
    padding: 6px 8px 4px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 4px;
    border-bottom: 1px solid #f0f2f4;
    background: #f8f9fa;
}
.cal-day__num {
    font-size: 15px;
    font-weight: 700;
    color: #1a2e4a;
    line-height: 1;
}
.cal-day--out .cal-day__num { color: #c5cdd6; }
.cal-day--today .cal-day__num {
    background: #2980b9;
    color: #fff;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
}
.cal-day__body {
    flex: 1;
    padding: 4px 6px 6px;
    display: flex;
    flex-direction: column;
    gap: 3px;
}
.cal-add-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 1.5px solid #2980b9;
    background: #fff;
    color: #2980b9;
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
    padding: 0;
}
.cal-add-btn:hover { background: #2980b9; color: #fff; }

/* ── Location cards inside calendar ── */
.cal-card {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    padding: 5px 7px;
    border-radius: 6px;
    border: 1px solid #eaecef;
    background: #fff;
    font-size: 11px;
    color: #2c3e50;
    user-select: none;
    position: relative;
}
.cal-card:hover { border-color: #b0c4d8; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
.cal-card__icon { flex-shrink: 0; font-size: 12px; line-height: 1.3; }
.cal-card__text { flex: 1; min-width: 0; }
.cal-card__title { font-weight: 600; line-height: 1.3; word-break: break-word; }
.cal-card__type { font-size: 10px; color: #95a5a6; }
.cal-remove-btn {
    flex-shrink: 0;
    background: none;
    border: none;
    color: #c5cdd6;
    font-size: 13px;
    line-height: 1;
    cursor: pointer;
    padding: 0 1px;
    border-radius: 3px;
    transition: color 0.15s;
    align-self: flex-start;
}
.cal-remove-btn:hover { color: #e74c3c; }

/* Sidebar cards (larger) */
.cal-unscheduled .cal-card {
    font-size: 12px;
    padding: 7px 8px;
    margin-bottom: 4px;
}

/* ── Picker dropdown ── */
.cal-picker {
    position: fixed;
    z-index: 3000;
    background: #fff;
    border: 1px solid #dde3ea;
    border-radius: 10px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.15);
    min-width: 200px;
    max-width: 260px;
    max-height: 280px;
    overflow-y: auto;
    padding: 6px;
    display: none;
}
.cal-picker.is-open { display: block; }
.cal-picker__empty {
    font-size: 12px;
    color: #b0bec5;
    text-align: center;
    padding: 14px 8px;
}
.cal-picker__item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 7px;
    font-size: 12px;
    color: #2c3e50;
    cursor: pointer;
    transition: background 0.12s;
}
.cal-picker__item:hover { background: #eaf4fd; }
.cal-picker__item__icon { flex-shrink: 0; font-size: 13px; }
.cal-picker__item__title { font-weight: 600; line-height: 1.3; }
.cal-picker__item__type { font-size: 10px; color: #95a5a6; }

/* Connected user badge */
.st-online-badge {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 1200;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.2);
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.2px;
    text-decoration: none;
    pointer-events: none;
    transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
}

.st-online-badge--connected {
    background: linear-gradient(135deg, #1f9d55 0%, #17946e 100%);
    border-color: rgba(255, 255, 255, 0.35);
    box-shadow: 0 8px 22px rgba(16, 92, 69, 0.35);
}

.st-online-badge--disconnected {
    background: linear-gradient(135deg, #6c7a89 0%, #566270 100%);
    border-color: rgba(255, 255, 255, 0.25);
    box-shadow: 0 8px 22px rgba(60, 70, 80, 0.35);
}

.st-online-badge--connecting {
    background: linear-gradient(135deg, #f39c12 0%, #d68910 100%);
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 22px rgba(211, 137, 16, 0.35);
}

.st-online-badge--connecting .st-online-badge__dot {
    background: #fff4d2;
    animation: st-online-pulse 0.8s infinite;
}

.st-online-badge:hover,
.st-online-badge:focus {
    color: #ffffff;
    text-decoration: none;
}

.st-online-badge__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #e9fff3;
    box-shadow: 0 0 0 0 rgba(233, 255, 243, 0.8);
    animation: st-online-pulse 1.6s infinite;
}

.st-online-badge--disconnected .st-online-badge__dot {
    background: #dde3ea;
    animation: none;
    box-shadow: none;
}

@keyframes st-online-pulse {
    0% {
        box-shadow: 0 0 0 0 rgba(233, 255, 243, 0.85);
    }
    70% {
        box-shadow: 0 0 0 10px rgba(233, 255, 243, 0);
    }
    100% {
        box-shadow: 0 0 0 0 rgba(233, 255, 243, 0);
    }
}

/* ─────────────────────────────────────────
   Responsive
───────────────────────────────────────── */
@media (max-width: 991px) {
    .st-map-locations {
        grid-template-columns: 1fr;
        min-height: auto;
        transition: none;
    }
    .st-map-locations.sidebar-collapsed {
        grid-template-columns: 1fr;
    }
    .st-map-area {
        min-height: 350px;
    }
    #map {
        min-height: 350px;
    }
    .st-locations-sidebar {
        border-left: none;
        border-top: 1px solid #eaecef;
        height: 300px;
        width: 100% !important;
        opacity: 1 !important;
    }
    .st-sidebar-toggle { display: none; }
    .st-details-row { grid-template-columns: 1fr; }
    .pa-header__inner { flex-direction: column; align-items: flex-start; gap: 12px; }
    .pa-header__right { width: 100%; }
}
@media (max-width: 600px) {
    .pa-header__title { font-size: 20px; }
    .pa-header__left  { gap: 12px; }
    .st-map-area, #map { min-height: 280px; }
    .st-online-badge {
        right: 12px;
        bottom: 12px;
        padding: 8px 12px;
        font-size: 12px;
    }
}
    </style>
{% endblock %}

{% block content %}
<div class="st-page">

    {# ── Header (pa-header) ── #}
    <div class="pa-header">
        <div class="container">
            <div class="pa-header__inner">
                <div class="pa-header__left">
                    <div class="pa-header__icon">✈</div>
                    <div class="pa-header__titles">
                        <a href="{{ path('homepage') }}" class="pa-header__back">
                            <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3L5 8l5 5"/></svg>
                            Home
                        </a>
                        <h1 class="pa-header__title">{{ travel.title }}</h1>
                        <p class="pa-header__sub">
                            {% if travel.description %}
                                <span>{{ travel.description }}</span>
                            {% endif %}
                            <span class="pa-header__meta-item">
                                <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor"><path d="M11 1v1H5V1H3v1H1v13h14V2h-2V1h-2zm2 12H3V6h10v7z"/></svg>
                                {{ travel.startAt|date("d M Y") }} – {{ travel.endAt|date("d M Y") }}
                            </span>
                            <span class="pa-header__meta-item">
                                By <strong>{{ travel.user.firstName }} {{ travel.user.lastname }}</strong>
                            </span>
                            <span id="panel-information"></span>
                        </p>
                    </div>
                </div>
                <div class="pa-header__right">
                    <span class="pa-stat-pill">
                        <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M8 1l1.8 3.6L14 5.3l-3 2.9.7 4.1L8 10.4l-3.7 1.9.7-4.1-3-2.9 4.2-.7z"/></svg>
                        {{ travel.stars }}
                    </span>
                    <span class="pa-stat-pill">
                        <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M8 3C4.5 3 1.5 6 1 8c.5 2 3.5 5 7 5s6.5-3 7-5c-.5-2-3.5-5-7-5zm0 8a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0-5a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/></svg>
                        {{ travel.watch }}
                    </span>
                    {% if app.user and app.user.userId == travel.user.userId %}
                        <button type="button" class="pa-btn-new pa-btn-share" id="st-share-btn"
                                data-travel-id="{{ travel.id }}">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M12 10a2 2 0 0 0-1.6.8L5.9 8.4a2 2 0 0 0 0-1.8l4.5-2.4A2 2 0 1 0 9.6 2.2L5.1 4.6a2 2 0 1 0 0 5.8l4.5 2.4A2 2 0 1 0 12 10z"/></svg>
                            Share
                        </button>
                        <a href="{{ path('updateTravel', {'slug': travel.slug}) }}" class="pa-btn-new">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M11.7 1.3a1 1 0 0 1 1.4 0l1.6 1.6a1 1 0 0 1 0 1.4L5.5 13.5 1 15l1.5-4.5 9.2-9.2z"/></svg>
                            Edit travel
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# ── Body ── #}
    <div class="container">

        <div id="infoTravel"></div>

        {# ── View tab switcher ── #}
        {% set canEdit = app.user is not null and (app.user.userId == travel.user.userId or travel.sharedusers|length > 0) %}
        <div class="st-view-tabs">
            <button class="st-view-tab is-active" data-tab="map" type="button">
                <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M8 1a5 5 0 0 1 5 5c0 4-5 9-5 9S3 10 3 6a5 5 0 0 1 5-5zm0 3a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/></svg>
                Map
            </button>
            <button class="st-view-tab" data-tab="calendar" type="button">
                <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M11 1v1H5V1H3v1H1v13h14V2h-2V1h-2zm2 12H3V6h10v7z"/></svg>
                Calendar
            </button>
        </div>

        {# ── MAP panel ── #}
        <div class="st-view-panel is-active" id="st-panel-map">
        <div class="st-layout">

            {# ── Mapa + Localizaciones (split view) ── #}
            <div class="st-map-locations">
                {# Mapa (lado izquierdo, grande) #}
                <div class="st-map-area">
                    <div class="st-panel__head">
                        <span class="st-panel__head-left">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M8 1a5 5 0 0 1 5 5c0 4-5 9-5 9S3 10 3 6a5 5 0 0 1 5-5zm0 3a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/></svg>
                            Map
                        </span>
                        <button class="st-sidebar-toggle" id="st-sidebar-toggle" type="button" title="Toggle locations panel">
                            <svg class="st-sidebar-toggle__icon" viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3l-5 5 5 5"/></svg>
                            <span id="st-sidebar-toggle-label">Hide</span>
                        </button>
                    </div>
                    <div id="map"></div>
                </div>

                {# Localizaciones (lado derecho, siempre visible) #}
                <div class="st-locations-sidebar">
                    {% include 'travel/locationsPanel.html.twig' %}
                </div>
            </div>

            {# ── Detalles adicionales (rutas, tracks, galería) ── #}
            <div class="st-details-row">
                <div class="st-sidebar">
                    {% include 'travel/routePanel.html.twig' %}
                    {% include 'travel/tracksPanel.html.twig' with {'gpxs': travel.gpx} %}
                </div>

                <div class="st-main">
                    {% include 'travel/infoLocationPanel.html.twig' with {'travel': travel} %}
                </div>
            </div>

        </div>

        {% include 'travel/modalFormAddPoint.html.twig' with {'travel': travel} %}

        </div>{# /st-panel-map #}

        {# ── CALENDAR panel ── #}
        <div class="st-view-panel" id="st-panel-calendar">
            <div class="cal-wrap">

                {# Unscheduled sidebar #}
                <div class="cal-unscheduled">
                    <div class="cal-unscheduled__head">Locations</div>
                    <div class="cal-unscheduled__body" id="cal-unscheduled">
                        {% set hasUnscheduled = false %}
                        {% for loc in travel.location %}
                            {% if loc.visitAt is null %}
                                {% set hasUnscheduled = true %}
                                <div class="cal-card" id="cal-loc-{{ loc.id }}"
                                     data-location-id="{{ loc.id }}"
                                     data-title="{{ loc.title|e('html_attr') }}"
                                     data-type="{{ loc.typeLocation is not null ? loc.typeLocation.title|e('html_attr') : '' }}"
                                     data-icon="{{ loc.typeLocation is not null ? loc.typeLocation.icon|e('html_attr') : '' }}">
                                    <span class="cal-card__icon">
                                        {% if loc.typeLocation is not null %}<i class="{{ loc.typeLocation.icon }}"></i>{% else %}📍{% endif %}
                                    </span>
                                    <span class="cal-card__text">
                                        <div class="cal-card__title">{{ loc.title }}</div>
                                        {% if loc.typeLocation is not null %}<div class="cal-card__type">{{ loc.typeLocation.title }}</div>{% endif %}
                                    </span>
                                </div>
                            {% endif %}
                        {% endfor %}
                        {% if not hasUnscheduled %}
                            <div class="cal-unscheduled__empty" id="cal-unscheduled-empty">All locations scheduled ✓</div>
                        {% endif %}
                    </div>
                </div>

                {# Week calendar #}
                <div class="cal-main">

                    {# Nav bar — rendered by JS #}
                    <div class="cal-nav">
                        <button class="cal-nav__btn" id="cal-prev" type="button" title="Previous week">
                            <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3L5 8l5 5"/></svg>
                        </button>
                        <span class="cal-nav__label" id="cal-nav-label"></span>
                        <button class="cal-nav__btn" id="cal-next" type="button" title="Next week">
                            <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3l5 5-5 5"/></svg>
                        </button>
                    </div>

                    <div class="cal-grid">
                        {# Day-of-week header #}
                        <div class="cal-grid__header">
                            {% for dow in ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'] %}
                                <div class="cal-grid__dow">{{ dow }}</div>
                            {% endfor %}
                        </div>
                        {# Day cells — all days of the trip pre-rendered, shown/hidden by JS week navigation #}
                        <div class="cal-grid__body" id="cal-grid-body">
                            {% set dayNames   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'] %}
                            {% set monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'] %}
                            {% set startTs = travel.startAt|date('U') %}
                            {% set endTs   = travel.endAt|date('U') %}
                            {% set numDays = ((endTs - startTs) / 86400)|round(0, 'ceil') + 1 %}
                            {# Find Monday of the week containing startAt (ISO: Mon=1) #}
                            {% set startDow = travel.startAt|date('N') %}
                            {% set gridStart = travel.startAt|date_modify('-' ~ (startDow - 1) ~ ' days') %}
                            {% set endDow = travel.endAt|date('N') %}
                            {% set gridEnd = travel.endAt|date_modify('+' ~ (7 - endDow) ~ ' days') %}
                            {% set gridStartTs = gridStart|date('U') %}
                            {% set gridEndTs   = gridEnd|date('U') %}
                            {% set gridDays = ((gridEndTs - gridStartTs) / 86400)|round(0,'ceil') + 1 %}
                            {% for i in 0..(gridDays - 1) %}
                                {% set thisDate    = gridStart|date_modify('+' ~ i ~ ' days') %}
                                {% set thisDateStr = thisDate|date('Y-m-d') %}
                                {% set inTrip      = thisDate|date('U') >= startTs and thisDate|date('U') <= endTs %}
                                <div class="cal-day{% if not inTrip %} cal-day--out{% endif %}"
                                     id="cal-day-{{ thisDateStr }}"
                                     data-date="{{ thisDateStr }}"
                                     data-week="{{ thisDate|date('Y-W') }}">
                                    <div class="cal-day__head">
                                        <span class="cal-day__num">{{ thisDate|date('d') }}</span>
                                        {% if canEdit and inTrip %}
                                        <button class="cal-add-btn" type="button" data-date="{{ thisDateStr }}" title="Add location">+</button>
                                        {% endif %}
                                    </div>
                                    <div class="cal-day__body">
                                        {% if inTrip %}
                                            {% for loc in travel.location %}
                                                {% if loc.visitAt is not null and loc.visitAt|date('Y-m-d') == thisDateStr %}
                                                    <div class="cal-card" id="cal-loc-{{ loc.id }}"
                                                         data-location-id="{{ loc.id }}"
                                                         data-title="{{ loc.title|e('html_attr') }}"
                                                         data-type="{{ loc.typeLocation is not null ? loc.typeLocation.title|e('html_attr') : '' }}"
                                                         data-icon="{{ loc.typeLocation is not null ? loc.typeLocation.icon|e('html_attr') : '' }}">
                                                        <span class="cal-card__icon">
                                                            {% if loc.typeLocation is not null %}<i class="{{ loc.typeLocation.icon }}"></i>{% else %}📍{% endif %}
                                                        </span>
                                                        <span class="cal-card__text">
                                                            <div class="cal-card__title">{{ loc.title }}</div>
                                                            {% if loc.typeLocation is not null %}<div class="cal-card__type">{{ loc.typeLocation.title }}</div>{% endif %}
                                                        </span>
                                                        {% if canEdit %}
                                                        <button class="cal-remove-btn" type="button" data-location-id="{{ loc.id }}" title="Unschedule">&times;</button>
                                                        {% endif %}
                                                    </div>
                                                {% endif %}
                                            {% endfor %}
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                </div>{# /cal-main #}

            </div>
        </div>{# /st-panel-calendar #}

    </div>{# /container #}

</div>{# /st-page #}

{% if app.user and app.user.userId == travel.user.userId %}
<div class="sh-overlay" id="sh-overlay" role="dialog" aria-modal="true" aria-labelledby="sh-modal-title">
    <div class="sh-modal">
        <button class="sh-modal__close" id="sh-modal-close" type="button" aria-label="Close">&times;</button>
        <h2 class="sh-modal__title" id="sh-modal-title">
            <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor"><path d="M12 10a2 2 0 0 0-1.6.8L5.9 8.4a2 2 0 0 0 0-1.8l4.5-2.4A2 2 0 1 0 9.6 2.2L5.1 4.6a2 2 0 1 0 0 5.8l4.5 2.4A2 2 0 1 0 12 10z"/></svg>
            Share travel
        </h2>
        <p class="sh-modal__sub">Enter the username of the person you want to share <strong>{{ travel.title }}</strong> with.</p>
        <div class="sh-modal__feedback" id="sh-feedback"></div>
        <div class="sh-modal__users" id="sh-users-section">
            <div class="sh-modal__users-title">Currently shared with</div>
            <div id="sh-users-list"><div class="sh-modal__users-empty">Loading…</div></div>
        </div>
        <hr class="sh-modal__divider">
        <div class="sh-modal__field">
            <label class="sh-modal__label" for="sh-username">Username</label>
            <input class="sh-modal__input" type="text" id="sh-username" placeholder="e.g. johndoe" autocomplete="off">
        </div>
        <div class="sh-modal__actions">
            <button class="sh-modal__btn sh-modal__btn--cancel" id="sh-cancel" type="button">Cancel</button>
            <button class="sh-modal__btn sh-modal__btn--submit" id="sh-submit" type="button">
                <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M12 10a2 2 0 0 0-1.6.8L5.9 8.4a2 2 0 0 0 0-1.8l4.5-2.4A2 2 0 1 0 9.6 2.2L5.1 4.6a2 2 0 1 0 0 5.8l4.5 2.4A2 2 0 1 0 12 10z"/></svg>
                Share
            </button>
        </div>
    </div>
</div>
{% endif %}

<a class="st-online-badge st-online-badge--disconnected" id="online-user">
    <span class="st-online-badge__dot"></span>
    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M3 8a5 5 0 1 1 10 0A5 5 0 0 1 3 8zm5-3a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/></svg>
    <span id="online-user-label">Usuario desconectado</span>
</a>
{% endblock %}

{% block javascript %}
    {{ parent() }}
    {% set canEdit = app.user is not null and (app.user.userId == travel.user.userId or travel.sharedusers|length > 0) %}
    <script src="{{ asset('js/jquery.ui.widget.js') }}"></script>
    <script src="{{ asset('js/jquery.iframe-transport.js') }}"></script>
    <script src="{{ asset('js/jquery.fileupload.js') }}"></script>
    <script src="{{ asset('js/json2.js') }}"></script>
    <script src="{{ asset('js/jquery.sortable.js') }}"></script>
    <script src="{{ asset('js/leaflet@1.7.1/leaflet.js') }}"></script>
    <script src="{{ asset('js/autocomplete@1.8.3/autocomplete.js')}}"></script>
    <script src="{{ asset('js/autocomplete/popUpAutocomplete.js') }}"></script>
    <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.js"></script>
    <script src="{{ asset('leaflet/leaflet-plugins-master/layer/tile/Google.js') }}"></script>
    <script src="{{ asset('js/leaflet.awesome-markers.min.js') }}"></script>
    <script src='https://api.mapbox.com/mapbox.js/plugins/leaflet-fullscreen/v1.0.1/Leaflet.fullscreen.min.js'></script>
    <script src="{{ asset('leaflet/leaflet-gpx-master/gpx.js') }}"></script>
    <script src="{{ asset('js/markersDefinition.js') }}"></script>
    <script src="{{ asset('js/mapPoint.js') }}"></script>
    <script src="{{ asset('js/locationGallery.js') }}"></script>
    <script>
        var WS_TRAVEL_ID = '{{ travel.id }}';
        var WS_CURRENT_USER_ID = '{{ app.user ? app.user.id : '' }}';
    </script>
    <script src="{{ asset('js/websocket/websockets.js') }}?v={{ "now"|date('U') }}"></script>
    <script src="{{ asset('leaflet/leaflet-easyprint.js') }}"></script>
    <script>
        var mPoint = new mapPoint('{{ travel.id }}');
        mPoint.addPlugin('locationGallery',new locationGallery('{{ asset('uploads/gallery/') }}'));

        var map = L.map('map',{
            center: [{{ travel.geolocation.lat}},{{ travel.geolocation.lng }}],
            zoom:8,
            fullscreenControl: { pseudoFullscreen: false }
        });
        var geocoder = new google.maps.Geocoder();

        var osm           = new L.TileLayer('http://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png');
        var googleTerrain = L.tileLayer('http://{s}.google.com/vt/lyrs=p&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] });
        var googleSat     = L.tileLayer('http://{s}.google.com/vt/lyrs=s&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] });
        var googleHybrid  = L.tileLayer('http://{s}.google.com/vt/lyrs=s,h&x={x}&y={y}&z={z}', { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] });
        var googleRoadMap = L.tileLayer('http://{s}.google.com/vt/lyrs=m&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] }).addTo(map);
        var googleTraffic = L.tileLayer('https://{s}.google.com/vt/lyrs=m@221097413,traffic&x={x}&y={y}&z={z}', { maxZoom: 20, minZoom: 2, subdomains:['mt0','mt1','mt2','mt3'] });

        map.addControl(new L.Control.Layers({'OSM':osm,'Google Hybrid':googleHybrid,'Google Satellite':googleSat,'Google Terrain':googleTerrain,'Road Map':googleRoadMap,'Traffic':googleTraffic}, {}));

        var centralMark = L.marker([{{ travel.geolocation.lat}},{{ travel.geolocation.lng }}], {icon: centerMarker}).addTo(map);

        /* ── Locations sidebar collapse ── */
        (function () {
            var wrapper = document.querySelector('.st-map-locations');
            var btn     = document.getElementById('st-sidebar-toggle');
            var label   = document.getElementById('st-sidebar-toggle-label');

            btn.addEventListener('click', function () {
                var collapsed = wrapper.classList.toggle('sidebar-collapsed');
                label.textContent = collapsed ? 'Show' : 'Hide';
                setTimeout(function () { map.invalidateSize(); }, 310);
            });
        }());

        $('#center').click(function()          { map.setView([{{ travel.geolocation.lat}},{{ travel.geolocation.lng }}],8); });
        $('#remove-route').click(function()    { mPoint.removeRoute(); });
        $('#calculate-route').click(function() { mPoint.calculateRoute(); });
        $('#reset').click(function()           { mPoint.resetRoute(); });
        $('#itinerary').click(function()       { mPoint.panelItinerary(); });

        function initialize() {
            {% include 'travel/loadPointsMap.html.twig' with {'locations': travel.location} %}
        }
        initialize();

        var printer = L.easyPrint({
            tileLayer: googleRoadMap,
            sizeModes: ['Current', 'A4Landscape', 'A4Portrait'],
            filename: 'myMap',
            exportOnly: true,
            hideControlContainer: true
        }).addTo(map);
    </script>

    {% if app.user and app.user.userId == travel.user.userId %}
    <script>
    (function () {
        var overlay  = document.getElementById('sh-overlay');
        var closeBtn = document.getElementById('sh-modal-close');
        var cancelBtn= document.getElementById('sh-cancel');
        var submitBtn= document.getElementById('sh-submit');
        var input    = document.getElementById('sh-username');
        var feedback = document.getElementById('sh-feedback');
        var openBtn  = document.getElementById('st-share-btn');
        var travelId = openBtn ? openBtn.getAttribute('data-travel-id') : null;
        var shareUrl       = '{{ path('shareTravelAPI',      {'travelId': '__ID__'}) }}'.replace('__ID__', travelId);
        var sharedUsersUrl = '{{ path('getSharedUsersAPI',   {'travelId': '__ID__'}) }}'.replace('__ID__', travelId);
        var unshareBaseUrl = '{{ path('unshareTravelAPI',    {'travelId': '__ID__', 'username': '__USER__'}) }}';

        function unshareUrl(username) {
            return unshareBaseUrl.replace('__ID__', travelId).replace('__USER__', encodeURIComponent(username));
        }

        function loadSharedUsers() {
            var list = document.getElementById('sh-users-list');
            list.innerHTML = '<div class="sh-modal__users-empty">Loading…</div>';
            fetch(sharedUsersUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(function (r) { return r.json(); })
                .then(function (data) { renderSharedUsers(data.users || []); })
                .catch(function () { list.innerHTML = '<div class="sh-modal__users-empty">Could not load.</div>'; });
        }

        function renderSharedUsers(users) {
            var list = document.getElementById('sh-users-list');
            if (!users.length) {
                list.innerHTML = '<div class="sh-modal__users-empty">Not shared with anyone yet.</div>';
                return;
            }
            list.innerHTML = users.map(function (u) {
                var display = escHtml(u.firstName || '') + ' ' + escHtml(u.lastName || '');
                return '<div class="sh-user-row" id="sh-user-' + escHtml(u.username) + '">' +
                    '<span class="sh-user-row__name">' + escHtml(u.username) + '<small>' + display.trim() + '</small></span>' +
                    '<button class="sh-user-revoke" data-username="' + escHtml(u.username) + '" type="button">Revoke</button>' +
                    '</div>';
            }).join('');
            list.querySelectorAll('.sh-user-revoke').forEach(function (btn) {
                btn.addEventListener('click', function () { doRevoke(this.getAttribute('data-username')); });
            });
        }

        function doRevoke(username) {
            fetch(unshareUrl(username), {
                method: 'DELETE',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
            .then(function (result) {
                if (result.ok) {
                    var row = document.getElementById('sh-user-' + username);
                    if (row) { row.remove(); }
                    var list = document.getElementById('sh-users-list');
                    if (!list.querySelector('.sh-user-row')) {
                        list.innerHTML = '<div class="sh-modal__users-empty">Not shared with anyone yet.</div>';
                    }
                } else {
                    showFeedback('error', result.data.error || 'Could not revoke access.');
                }
            })
            .catch(function () { showFeedback('error', 'Network error revoking access.'); });
        }

        function openModal() {
            overlay.classList.add('is-open');
            input.value = '';
            feedback.className = 'sh-modal__feedback';
            feedback.textContent = '';
            loadSharedUsers();
            setTimeout(function () { input.focus(); }, 50);
        }

        function closeModal() {
            overlay.classList.remove('is-open');
        }

        if (openBtn) { openBtn.addEventListener('click', openModal); }
        if (closeBtn) { closeBtn.addEventListener('click', closeModal); }
        if (cancelBtn) { cancelBtn.addEventListener('click', closeModal); }

        overlay.addEventListener('click', function (e) {
            if (e.target === overlay) { closeModal(); }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { closeModal(); }
        });

        input.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { doShare(); }
        });

        submitBtn.addEventListener('click', doShare);

        function doShare() {
            var username = input.value.trim();
            if (!username) {
                showFeedback('error', 'Please enter a username.');
                input.focus();
                return;
            }

            submitBtn.disabled = true;
            submitBtn.textContent = 'Sharing…';

            fetch(shareUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ username: username })
            })
            .then(function (res) {
                return res.text().then(function (text) {
                    var data = null;
                    try { data = JSON.parse(text); } catch (e) {}
                    return { ok: res.ok, status: res.status, data: data, raw: text };
                });
            })
            .then(function (result) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M12 10a2 2 0 0 0-1.6.8L5.9 8.4a2 2 0 0 0 0-1.8l4.5-2.4A2 2 0 1 0 9.6 2.2L5.1 4.6a2 2 0 1 0 0 5.8l4.5 2.4A2 2 0 1 0 12 10z"/></svg> Share';
                if (result.ok) {
                    showFeedback('success', 'Travel shared with <strong>' + escHtml(username) + '</strong>.');
                    input.value = '';
                    loadSharedUsers();
                } else if (result.data && result.data.error) {
                    showFeedback('error', result.data.error);
                } else {
                    showFeedback('error', 'Server error ' + result.status + (result.raw ? ': ' + result.raw.substring(0, 120) : ''));
                }
            })
            .catch(function (err) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M12 10a2 2 0 0 0-1.6.8L5.9 8.4a2 2 0 0 0 0-1.8l4.5-2.4A2 2 0 1 0 9.6 2.2L5.1 4.6a2 2 0 1 0 0 5.8l4.5 2.4A2 2 0 1 0 12 10z"/></svg> Share';
                showFeedback('error', 'Network error: ' + (err && err.message ? err.message : String(err)));
            });
        }

        function showFeedback(type, html) {
            feedback.className = 'sh-modal__feedback is-' + type;
            feedback.innerHTML = html;
        }

        function escHtml(str) {
            return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
    }());
    </script>
    {% endif %}

    <script>
    (function () {
        /* ── Tab switcher ── */
        var tabs  = document.querySelectorAll('.st-view-tab');
        var panels = document.querySelectorAll('.st-view-panel');
        tabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
                tabs.forEach(function (t) { t.classList.remove('is-active'); });
                panels.forEach(function (p) { p.classList.remove('is-active'); });
                tab.classList.add('is-active');
                var target = document.getElementById('st-panel-' + tab.dataset.tab);
                if (target) { target.classList.add('is-active'); }
                if (tab.dataset.tab === 'map') {
                    setTimeout(function () { if (typeof map !== 'undefined') { map.invalidateSize(); } }, 50);
                }
            });
        });

        {% if canEdit is defined and canEdit %}
        /* ── Calendar: picker + week navigation ── */
        var VISIT_DATE_URL = '{{ path('updateLocationVisitDate', {'locationId': '__LOC__'}) }}';
        {% endif %}

        /* ── Week navigation (all users) ── */
        var allDays   = Array.from(document.querySelectorAll('#cal-grid-body .cal-day'));
        var weeks     = [];
        var weekMap   = {};
        allDays.forEach(function (d) {
            var w = d.dataset.week;
            if (!weekMap[w]) { weekMap[w] = []; weeks.push(w); }
            weekMap[w].push(d);
        });
        var currentWeekIdx = 0;

        /* Start on the week that contains the first trip day */
        var firstTripDay = allDays.find(function (d) { return !d.classList.contains('cal-day--out'); });
        if (firstTripDay) {
            var fw = firstTripDay.dataset.week;
            var fi = weeks.indexOf(fw);
            if (fi >= 0) { currentWeekIdx = fi; }
        }

        function showWeek(idx) {
            allDays.forEach(function (d) { d.style.display = 'none'; });
            var w = weeks[idx];
            if (!w) return;
            (weekMap[w] || []).forEach(function (d) { d.style.display = 'flex'; });
            var days = weekMap[w];
            var first = days[0].dataset.date;
            var last  = days[days.length - 1].dataset.date;
            var fmt = function (s) {
                var p = s.split('-'); var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                return months[parseInt(p[1],10)-1] + ' ' + parseInt(p[2],10) + ', ' + p[0];
            };
            document.getElementById('cal-nav-label').textContent = fmt(first) + ' – ' + fmt(last);
            document.getElementById('cal-prev').disabled = (idx === 0);
            document.getElementById('cal-next').disabled = (idx === weeks.length - 1);
        }

        if (allDays.length > 0) {
            showWeek(currentWeekIdx);
            document.getElementById('cal-prev').addEventListener('click', function () {
                if (currentWeekIdx > 0) { currentWeekIdx--; showWeek(currentWeekIdx); }
            });
            document.getElementById('cal-next').addEventListener('click', function () {
                if (currentWeekIdx < weeks.length - 1) { currentWeekIdx++; showWeek(currentWeekIdx); }
            });
        }

        {% if canEdit is defined and canEdit %}
        /* ── Picker ── */
        var picker = document.createElement('div');
        picker.className = 'cal-picker';
        picker.id = 'cal-picker';
        document.body.appendChild(picker);
        var pickerDate = null;

        function openPicker(btn) {
            pickerDate = btn.dataset.date;
            var unscheduled = document.querySelectorAll('#cal-unscheduled .cal-card');
            picker.innerHTML = '';
            if (unscheduled.length === 0) {
                picker.innerHTML = '<div class="cal-picker__empty">No unscheduled locations</div>';
            } else {
                unscheduled.forEach(function (card) {
                    var item = document.createElement('div');
                    item.className = 'cal-picker__item';
                    var iconAttr = card.dataset.icon || '';
                    var iconHtml = iconAttr
                        ? '<i class="cal-picker__item__icon ' + escAttr(iconAttr) + '"></i>'
                        : '<span class="cal-picker__item__icon">📍</span>';
                    item.innerHTML = iconHtml +
                        '<span><div class="cal-picker__item__title">' + escHtml(card.dataset.title || '') + '</div>' +
                        (card.dataset.type ? '<div class="cal-picker__item__type">' + escHtml(card.dataset.type) + '</div>' : '') +
                        '</span>';
                    item.addEventListener('click', function () {
                        scheduleLocation(card, pickerDate);
                        closePicker();
                    });
                    picker.appendChild(item);
                });
            }
            var rect = btn.getBoundingClientRect();
            picker.classList.add('is-open');
            var pw = picker.offsetWidth;
            var left = rect.left;
            if (left + pw > window.innerWidth - 8) { left = window.innerWidth - pw - 8; }
            picker.style.top  = (rect.bottom + window.scrollY + 4) + 'px';
            picker.style.left = Math.max(4, left) + 'px';
        }

        function closePicker() { picker.classList.remove('is-open'); pickerDate = null; }

        document.addEventListener('click', function (e) {
            if (!picker.contains(e.target) && !e.target.closest('.cal-add-btn')) { closePicker(); }
        });
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.cal-add-btn');
            if (!btn) return;
            e.stopPropagation();
            if (picker.classList.contains('is-open') && pickerDate === btn.dataset.date) { closePicker(); }
            else { openPicker(btn); }
        });
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.cal-remove-btn');
            if (!btn) return;
            var card = document.getElementById('cal-loc-' + btn.dataset.locationId);
            if (card) { unscheduleLocation(card); }
        });

        function scheduleLocation(card, date) {
            var locationId = card.dataset.locationId;
            var dayBody = document.querySelector('#cal-day-' + date + ' .cal-day__body');
            if (!dayBody) return;
            var scheduled = card.cloneNode(true);
            scheduled.id = 'cal-loc-' + locationId;
            var removeBtn = document.createElement('button');
            removeBtn.className = 'cal-remove-btn'; removeBtn.type = 'button';
            removeBtn.dataset.locationId = locationId; removeBtn.title = 'Unschedule';
            removeBtn.innerHTML = '&times;';
            scheduled.appendChild(removeBtn);
            card.remove();
            dayBody.appendChild(scheduled);
            updateUnscheduledEmpty();
            patchVisitDate(locationId, date, function () {
                scheduled.remove();
                document.getElementById('cal-unscheduled').appendChild(card);
                updateUnscheduledEmpty();
            });
        }

        function unscheduleLocation(card) {
            var locationId = card.dataset.locationId;
            var plain = card.cloneNode(true);
            plain.id = 'cal-loc-' + locationId;
            var oldBtn = plain.querySelector('.cal-remove-btn');
            if (oldBtn) { oldBtn.remove(); }
            card.remove();
            document.getElementById('cal-unscheduled').appendChild(plain);
            updateUnscheduledEmpty();
            patchVisitDate(locationId, null, function () { location.reload(); });
        }

        function patchVisitDate(locationId, date, onError) {
            var url = VISIT_DATE_URL.replace('__LOC__', locationId);
            fetch(url, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ visitAt: date })
            })
            .then(function (r) {
                if (!r.ok) { onError(); return; }
                return r.text().then(function (text) {
                    try {
                        var d = JSON.parse(text);
                        if (!d.success) { onError(); }
                    } catch (e) {
                        /* non-JSON but HTTP 2xx — treat as success */
                    }
                });
            })
            .catch(function () { /* network error — keep optimistic UI */ });
        }

        function updateUnscheduledEmpty() {
            var body    = document.getElementById('cal-unscheduled');
            var cards   = body.querySelectorAll('.cal-card');
            var emptyEl = document.getElementById('cal-unscheduled-empty');
            if (cards.length === 0 && !emptyEl) {
                var div = document.createElement('div');
                div.className = 'cal-unscheduled__empty'; div.id = 'cal-unscheduled-empty';
                div.textContent = 'All locations scheduled ✓';
                body.appendChild(div);
            } else if (cards.length > 0 && emptyEl) { emptyEl.remove(); }
        }

        function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
        function escAttr(s) { return String(s).replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
        {% endif %}
    }());
    </script>
