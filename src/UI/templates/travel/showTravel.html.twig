{% extends 'old_base.html.twig' %}

{% block title %}Travel {{travel.title }}{% endblock %}

{% block navbar %}
    {% include 'default/navbarPublic.html.twig' %}
{% endblock %}

{% block css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/leaflet@1.7.1/leaflet.css')}}"/>
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.css"/>
    <link rel="stylesheet" href="{{ asset('font-awesome-4.3.0/css/font-awesome.min.css') }}"/>
    <link rel="stylesheet" href="{{ asset('css/ionicons-2.0.1/css/ionicons.min.css') }}"/>
    <link rel="stylesheet" href="{{ asset('css/leaflet.awesome-markers.css')}}"/>
    <link rel="stylesheet" href="{{ asset('css/dropzone.css')}}"/>
    <link rel="stylesheet" href="{{ asset('css/autocomplete@1.8.3/autocomplete.min.css') }}"/>
    <link href='https://api.mapbox.com/mapbox.js/plugins/leaflet-fullscreen/v1.0.1/leaflet.fullscreen.css' rel='stylesheet'/>
    <style>
/* ─────────────────────────────────────────
   Page shell
───────────────────────────────────────── */
.st-page {
    background: #f4f6f8;
    min-height: calc(100vh - 64px);
    padding-bottom: 60px;
}

/* ─────────────────────────────────────────
   Hero header
───────────────────────────────────────── */
.st-hero {
    background: linear-gradient(135deg, #1a2e4a 0%, #2980b9 100%);
    padding: 28px 0 24px;
    margin-bottom: 28px;
}
.st-hero__inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
}
.st-hero__left { display: flex; flex-direction: column; gap: 8px; }
.st-back {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: rgba(255,255,255,0.65);
    font-size: 13px;
    text-decoration: none;
    transition: color 0.15s;
}
.st-back:hover { color: #fff; text-decoration: none; }
.st-hero__title {
    font-size: 26px;
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.2;
}
.st-hero__desc {
    font-size: 14px;
    color: rgba(255,255,255,0.75);
    margin: 0;
}
.st-hero__meta {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 4px;
}
.st-hero__meta-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    color: rgba(255,255,255,0.75);
}
.st-hero__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
}
.st-stats {
    display: flex;
    gap: 10px;
}
.st-stat {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
}
.st-author {
    font-size: 12px;
    color: rgba(255,255,255,0.6);
    text-align: right;
}
.st-author strong { color: rgba(255,255,255,0.9); }
.st-edit-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 16px;
    background: rgba(255,255,255,0.15);
    border: 1.5px solid rgba(255,255,255,0.3);
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
}
.st-edit-btn:hover { background: rgba(255,255,255,0.25); border-color: rgba(255,255,255,0.5); color: #fff; text-decoration: none; }

/* ─────────────────────────────────────────
   Layout
───────────────────────────────────────── */
.st-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 20px;
    align-items: start;
}
.st-sidebar { display: flex; flex-direction: column; gap: 16px; }
.st-main    { display: flex; flex-direction: column; gap: 16px; }

/* ─────────────────────────────────────────
   Panels
───────────────────────────────────────── */
.st-panel {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07), 0 4px 16px rgba(0,0,0,0.05);
    overflow: hidden;
}
.st-panel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 11px 16px;
    background: #f8f9fa;
    border-bottom: 1px solid #eaecef;
    font-size: 12px;
    font-weight: 700;
    color: #2c3e50;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.st-panel__head-left { display: flex; align-items: center; gap: 7px; }
.st-panel__body { padding: 0; }
.st-panel__body--pad { padding: 16px; }

/* ─────────────────────────────────────────
   Panel buttons
───────────────────────────────────────── */
.st-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 12px;
    font-size: 12px;
    font-weight: 600;
    border-radius: 16px;
    border: 1.5px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    white-space: nowrap;
}
.st-btn:active { transform: scale(0.97); }
.st-btn--primary {
    background: #2980b9;
    color: #fff;
    border-color: #2980b9;
}
.st-btn--primary:hover { background: #1e6fa8; border-color: #1e6fa8; color: #fff; text-decoration: none; }
.st-btn--warning {
    background: #f39c12;
    color: #fff;
    border-color: #f39c12;
}
.st-btn--warning:hover { background: #e67e22; border-color: #e67e22; color: #fff; text-decoration: none; }
.st-btn--danger {
    background: #e74c3c;
    color: #fff;
    border-color: #e74c3c;
}
.st-btn--danger:hover { background: #c0392b; border-color: #c0392b; color: #fff; text-decoration: none; }
.st-btn--ghost {
    background: #f4f6f8;
    color: #636e72;
    border-color: #dde3ea;
}
.st-btn--ghost:hover { background: #eaecef; color: #2c3e50; text-decoration: none; }

/* ─────────────────────────────────────────
   Map
───────────────────────────────────────── */
#map {
    height: 500px;
    width: 100%;
    display: block;
    border-radius: 0 0 12px 12px;
}

/* ─────────────────────────────────────────
   Locations list
───────────────────────────────────────── */
#mapPoints {
    max-height: 460px;
    overflow-y: auto;
    padding: 8px;
}
#mapPoints::-webkit-scrollbar { width: 5px; }
#mapPoints::-webkit-scrollbar-track { background: #f4f6f8; }
#mapPoints::-webkit-scrollbar-thumb { background: #c5cdd6; border-radius: 3px; }

/* ─────────────────────────────────────────
   Route panel
───────────────────────────────────────── */
#routePoints {
    max-height: 240px;
    overflow-y: auto;
    padding: 8px;
    font-size: 13px;
    color: #636e72;
}
.st-panel-footer {
    display: flex;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid #eaecef;
    background: #f8f9fa;
    flex-wrap: wrap;
}

/* ─────────────────────────────────────────
   Tracks panel
───────────────────────────────────────── */
#tracks {
    max-height: 180px;
    overflow-y: auto;
    padding: 8px;
    font-size: 13px;
    color: #636e72;
}

/* ─────────────────────────────────────────
   Gallery / info panel
───────────────────────────────────────── */
#location_media { display: none; }
#location_media.is-visible { display: block; }

.st-gallery-title {
    font-size: 13px;
    font-weight: 600;
    color: #2c3e50;
}
#dz-ImageLocation {
    min-height: 80px;
}
.st-notes-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    color: #7f8c8d;
    margin-bottom: 6px;
}
#notes {
    font-size: 13px;
    color: #2c3e50;
    line-height: 1.6;
}

/* ─────────────────────────────────────────
   Point card (injected by JS)
───────────────────────────────────────── */
.point-view {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid #eaecef;
    margin-bottom: 6px;
    cursor: move;
    background: #fff;
    transition: border-color 0.15s, box-shadow 0.15s;
}
.point-view:hover {
    border-color: #c5cdd6;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.address-point { font-size: 12px; color: #7f8c8d; }
.title-point   { font-size: 13px; font-weight: 600; color: #2c3e50; }
.sortable-placeholder {
    border: 2px dashed #c5cdd6;
    border-radius: 8px;
    background: #f8f9fa;
    height: 44px;
    margin-bottom: 6px;
}

/* ─────────────────────────────────────────
   Info notification
───────────────────────────────────────── */
#infoTravel {
    margin-bottom: 16px;
}
#panel-information {
    font-size: 12px;
    color: rgba(255,255,255,0.6);
}

/* ─────────────────────────────────────────
   Responsive
───────────────────────────────────────── */
@media (max-width: 991px) {
    .st-layout { grid-template-columns: 1fr; }
    #map { height: 360px; }
    .st-hero__right { align-items: flex-start; }
    .st-author { text-align: left; }
}
@media (max-width: 600px) {
    .st-hero__title { font-size: 20px; }
    .st-stats { flex-wrap: wrap; }
}
    </style>
{% endblock %}

{% block content %}
<div class="st-page">

    {# ── Hero header ── #}
    <div class="st-hero">
        <div class="container">
            <div class="st-hero__inner">
                <div class="st-hero__left">
                    <a href="{{ path('homepage') }}" class="st-back">
                        <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3L5 8l5 5"/></svg>
                        Home
                    </a>
                    {% include 'travel/travelInfoHeader.html.twig' with {'travel': travel, 'mode': 'Edit'} %}
                </div>
                <div class="st-hero__right">
                    <div class="st-stats">
                        <span class="st-stat">
                            <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M8 1l1.8 3.6L14 5.3l-3 2.9.7 4.1L8 10.4l-3.7 1.9.7-4.1-3-2.9 4.2-.7z"/></svg>
                            {{ travel.stars }}
                        </span>
                        <span class="st-stat">
                            <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M8 3C4.5 3 1.5 6 1 8c.5 2 3.5 5 7 5s6.5-3 7-5c-.5-2-3.5-5-7-5zm0 8a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0-5a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/></svg>
                            {{ travel.watch }}
                        </span>
                    </div>
                    <div class="st-author">By <strong>{{ travel.user.firstName }} {{ travel.user.lastname }}</strong></div>
                    {% if mode is defined and mode == 'Edit' and app.user %}
                        <a href="#" class="st-edit-btn">
                            <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M11.5 2.5l2 2L5 13H3v-2L11.5 2.5zm1.4-1.4a1 1 0 0 1 1.4 1.4l-.7.7-2-2 .7-.7-.4.6z"/></svg>
                            Edit
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# ── Body ── #}
    <div class="container">

        <div id="infoTravel"></div>

        <div class="st-layout">

            {# ── Sidebar ── #}
            <div class="st-sidebar">
                {% include 'travel/locationsPanel.html.twig' %}
                {% include 'travel/routePanel.html.twig' %}
                {% include 'travel/tracksPanel.html.twig' with {'gpxs': travel.gpx} %}
            </div>

            {# ── Main ── #}
            <div class="st-main">
                {# Map panel #}
                <div class="st-panel">
                    <div class="st-panel__head">
                        <span class="st-panel__head-left">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" opacity=".7"><path d="M8 1a5 5 0 0 1 5 5c0 4-5 9-5 9S3 10 3 6a5 5 0 0 1 5-5zm0 3a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/></svg>
                            Map
                        </span>
                    </div>
                    <div id="map"></div>
                </div>

                {# Gallery / location info panel #}
                {% include 'travel/infoLocationPanel.html.twig' with {'travel': travel} %}
            </div>

        </div>

        {% include 'travel/modalFormAddPoint.html.twig' with {'travel': travel} %}

    </div>
</div>

{# WebSocket Status Badge #}
<a class="st-online-badge" style="display:none" id="online-user">
    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M3 8a5 5 0 1 1 10 0A5 5 0 0 1 3 8zm5-3a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/></svg>
    Connected
</a>

{# WebSocket Messages Container #}
<div id="websocket-messages"></div>
{% endblock %}

{% block javascript %}
    {{ parent() }}
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="{{ asset('js/jquery.ui.widget.js') }}"></script>
    <script src="{{ asset('js/jquery.iframe-transport.js') }}"></script>
    <script src="{{ asset('js/jquery.fileupload.js') }}"></script>
    <script src="{{ asset('js/json2.js') }}"></script>
    <script src="{{ asset('js/jquery.sortable.js') }}"></script>
    <script src="{{ asset('js/leaflet@1.7.1/leaflet.js') }}"></script>
    <script src="{{ asset('js/autocomplete@1.8.3/autocomplete.js')}}"></script>
    <script src="{{ asset('js/autocomplete/popUpAutocomplete.js') }}"></script>
    <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.js"></script>
    <script src="{{ asset('leaflet/leaflet-plugins-master/layer/tile/Google.js') }}"></script>
    <script src="{{ asset('js/leaflet.awesome-markers.min.js') }}"></script>
    <script src='https://api.mapbox.com/mapbox.js/plugins/leaflet-fullscreen/v1.0.1/Leaflet.fullscreen.min.js'></script>
    <script src="{{ asset('leaflet/leaflet-gpx-master/gpx.js') }}"></script>
    <script src="{{ asset('js/markersDefinition.js') }}"></script>
    <script src="{{ asset('js/mapPoint.js') }}"></script>
    <script src="{{ asset('js/locationGallery.js') }}"></script>
    <script src="{{ asset('js/websocket/websockets.js') }}"></script>
    <script src="{{ asset('leaflet/leaflet-easyprint.js') }}"></script>
    <script>
        var mPoint = new mapPoint('{{ travel.id }}');
        mPoint.addPlugin('locationGallery',new locationGallery('{{ asset('uploads/gallery/') }}'));

        var map = L.map('map',{
            center: [{{ travel.geolocation.lat}},{{ travel.geolocation.lng }}],
            zoom:8,
            fullscreenControl: { pseudoFullscreen: false }
        });
        var geocoder = new google.maps.Geocoder();

        var osm           = new L.TileLayer('http://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png');
        var googleTerrain = L.tileLayer('http://{s}.google.com/vt/lyrs=p&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] });
        var googleSat     = L.tileLayer('http://{s}.google.com/vt/lyrs=s&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] });
        var googleHybrid  = L.tileLayer('http://{s}.google.com/vt/lyrs=s,h&x={x}&y={y}&z={z}', { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] });
        var googleRoadMap = L.tileLayer('http://{s}.google.com/vt/lyrs=m&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] }).addTo(map);
        var googleTraffic = L.tileLayer('https://{s}.google.com/vt/lyrs=m@221097413,traffic&x={x}&y={y}&z={z}', { maxZoom: 20, minZoom: 2, subdomains:['mt0','mt1','mt2','mt3'] });

        map.addControl(new L.Control.Layers({'OSM':osm,'Google Hybrid':googleHybrid,'Google Satellite':googleSat,'Google Terrain':googleTerrain,'Road Map':googleRoadMap,'Traffic':googleTraffic}, {}));

        var centralMark = L.marker([{{ travel.geolocation.lat}},{{ travel.geolocation.lng }}], {icon: centerMarker}).addTo(map);

        $('#center').click(function()          { map.setView([{{ travel.geolocation.lat}},{{ travel.geolocation.lng }}],8); });
        $('#remove-route').click(function()    { mPoint.removeRoute(); });
        $('#calculate-route').click(function() { mPoint.calculateRoute(); });
        $('#reset').click(function()           { mPoint.resetRoute(); });
        $('#itinerary').click(function()       { mPoint.panelItinerary(); });

        function initialize() {
            {% include 'travel/loadPointsMap.html.twig' with {'locations': travel.location} %}
        }
        initialize();

        var printer = L.easyPrint({
            tileLayer: googleRoadMap,
            sizeModes: ['Current', 'A4Landscape', 'A4Portrait'],
            filename: 'myMap',
            exportOnly: true,
            hideControlContainer: true
        }).addTo(map);
    </script>
{% endblock %}

{% block aside %}{% endblock %}

{% block header_js %}
    <script type="text/javascript" src="{{ google_maps}}"></script>
{% endblock %}
