{% block javascript %}
    {{ parent() }}
    {% set isOwner = app.user is not null and app.user.userId == travel.user.userId %}
    {% set canEdit = isOwner or (app.user is not null and travel.sharedusers|filter(u => u.userId == app.user.userId)|length > 0) %}
    <script src="{{ asset('js/jquery.ui.widget.js') }}"></script>
    <script src="{{ asset('js/jquery.iframe-transport.js') }}"></script>
    <script src="{{ asset('js/jquery.fileupload.js') }}"></script>
    <script src="{{ asset('js/json2.js') }}"></script>
    <script src="{{ asset('js/jquery.sortable.js') }}"></script>
    <script src="{{ asset('js/leaflet@1.7.1/leaflet.js') }}"></script>
    <script src="{{ asset('js/autocomplete@1.8.3/autocomplete.js')}}"></script>
    <script src="{{ asset('js/autocomplete/popUpAutocomplete.js') }}"></script>
    <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.js"></script>
    <script src="{{ asset('leaflet/leaflet-plugins-master/layer/tile/Google.js') }}"></script>
    <script src="{{ asset('js/leaflet.awesome-markers.min.js') }}"></script>
    <script src='https://api.mapbox.com/mapbox.js/plugins/leaflet-fullscreen/v1.0.1/Leaflet.fullscreen.min.js'></script>
    <script src="{{ asset('leaflet/leaflet-gpx-master/gpx.js') }}"></script>
    <script src="{{ asset('js/markersDefinition.js') }}"></script>
    <script src="{{ asset('js/mapPoint.js') }}"></script>
    <script src="{{ asset('js/locationGallery.js') }}"></script>
    <script>
        var WS_TRAVEL_ID = '{{ travel.id }}';
        var WS_CURRENT_USER_ID = '{{ app.user ? app.user.id : '' }}';
        var WS_CURRENT_USERNAME = '{{ app.user ? app.user.username : '' }}';
    </script>
    <script src="{{ asset('js/websocket/websockets.js') }}?v={{ "now"|date('U') }}"></script>
    <script src="{{ asset('js/chat-widget.js') }}?v={{ "now"|date('U') }}"></script>
    {% if app.user %}
    <script>
        ChatWidget.init('{{ travel.id }}', '{{ app.user.id }}', '{{ app.user.username }}');
    </script>
    {% endif %}
    <script src="{{ asset('leaflet/leaflet-easyprint.js') }}"></script>
    <script>
        var mPoint = new mapPoint('{{ travel.id }}', {{ canEdit ? 'true' : 'false' }});
        mPoint.addPlugin('locationGallery',new locationGallery('{{ asset('uploads/gallery/') }}', {{ canEdit ? 'true' : 'false' }}));

        var map = L.map('map',{
            center: [{{ travel.geolocation.lat}},{{ travel.geolocation.lng }}],
            zoom:8,
            fullscreenControl: { pseudoFullscreen: false }
        });
        var geocoder = new google.maps.Geocoder();

        var osm           = new L.TileLayer('http://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png');
        var googleTerrain = L.tileLayer('http://{s}.google.com/vt/lyrs=p&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] });
        var googleSat     = L.tileLayer('http://{s}.google.com/vt/lyrs=s&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] });
        var googleHybrid  = L.tileLayer('http://{s}.google.com/vt/lyrs=s,h&x={x}&y={y}&z={z}', { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] });
        var googleRoadMap = L.tileLayer('http://{s}.google.com/vt/lyrs=m&x={x}&y={y}&z={z}',   { maxZoom: 20, subdomains:['mt0','mt1','mt2','mt3'] }).addTo(map);
        var googleTraffic = L.tileLayer('https://{s}.google.com/vt/lyrs=m@221097413,traffic&x={x}&y={y}&z={z}', { maxZoom: 20, minZoom: 2, subdomains:['mt0','mt1','mt2','mt3'] });

        map.addControl(new L.Control.Layers({'OSM':osm,'Google Hybrid':googleHybrid,'Google Satellite':googleSat,'Google Terrain':googleTerrain,'Road Map':googleRoadMap,'Traffic':googleTraffic}, {}));

        var centralMark = L.marker([{{ travel.geolocation.lat}},{{ travel.geolocation.lng }}], {icon: centerMarker}).addTo(map);

        /* ── Locations sidebar collapse ── */
        (function () {
            var wrapper = document.querySelector('.st-map-locations');
            var btn     = document.getElementById('st-sidebar-toggle');
            var label   = document.getElementById('st-sidebar-toggle-label');

            btn.addEventListener('click', function () {
                var collapsed = wrapper.classList.toggle('sidebar-collapsed');
                label.textContent = collapsed ? 'Show' : 'Hide';
                setTimeout(function () { map.invalidateSize(); }, 310);
            });
        }());

        /* ── Locations search & count ── */
        (function () {
            var searchInput = document.getElementById('loc-search');
            var countEl = document.getElementById('loc-count');
            var emptyState = document.getElementById('loc-empty-state');
            var mapPointsEl = document.getElementById('mapPoints');

            function updateCount() {
                var points = mapPointsEl.querySelectorAll('.point-view');
                var count = points.length;
                if (countEl) {
                    countEl.textContent = count + ' place' + (count !== 1 ? 's' : '');
                }
                if (emptyState) {
                    emptyState.style.display = count === 0 ? 'flex' : 'none';
                }
            }

            var observer = new MutationObserver(updateCount);
            observer.observe(mapPointsEl, { childList: true });
            updateCount();

            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    var query = this.value.toLowerCase().trim();
                    var points = mapPointsEl.querySelectorAll('.point-view');
                    points.forEach(function (point) {
                        var title = point.querySelector('.title-point b');
                        var address = point.querySelector('.address-point');
                        var text = (title ? title.textContent : '') + ' ' + (address ? address.textContent : '');
                        point.style.display = text.toLowerCase().includes(query) ? '' : 'none';
                    });
                });
            }
        }());

        $('#center').click(function()          { map.setView([{{ travel.geolocation.lat}},{{ travel.geolocation.lng }}],8); });
        $('#remove-route').click(function()    { mPoint.removeRoute(); });
        $('#calculate-route').click(function() { mPoint.calculateRoute(); });
        $('#reset').click(function()           { mPoint.resetRoute(); });
        $('#itinerary').click(function()       { mPoint.panelItinerary(); });

        function initialize() {
            {% include 'travel/loadPointsMap.html.twig' with {'locations': travel.location} %}
            {% if travel.gpx is defined and travel.gpx|length > 0 %}
            {% include 'travel/loadGpxTracks.html.twig' with {'gpxs': travel.gpx} %}
            {% endif %}
        }
        initialize();

        /* ── Track toggles ── */
        (function () {
            var checkboxes = document.querySelectorAll('.st-track-checkbox');
            checkboxes.forEach(function (cb) {
                cb.addEventListener('change', function () {
                    var idx = parseInt(this.getAttribute('data-track-idx'), 10);
                    var layer = gpxLayers[idx];
                    if (!layer) { return; }
                    if (this.checked) {
                        map.addLayer(layer);
                    } else {
                        map.removeLayer(layer);
                    }
                });
            });
            var showAllBtn = document.getElementById('tracks-show-all');
            if (showAllBtn) {
                showAllBtn.addEventListener('click', function () {
                    var allVisible = true;
                    checkboxes.forEach(function (cb) { if (!cb.checked) { allVisible = false; } });
                    checkboxes.forEach(function (cb) {
                        var idx = parseInt(cb.getAttribute('data-track-idx'), 10);
                        var layer = gpxLayers[idx];
                        if (!layer) { return; }
                        if (allVisible) {
                            cb.checked = false;
                            map.removeLayer(layer);
                        } else {
                            cb.checked = true;
                            map.addLayer(layer);
                        }
                    });
                    if (Object.keys(gpxLayers).length > 0) {
                        var bounds = map.getBounds();
                        var hasVisible = false;
                        checkboxes.forEach(function (cb) {
                            if (cb.checked) { hasVisible = true; }
                        });
                        if (hasVisible) {
                            var group = L.featureGroup();
                            checkboxes.forEach(function (cb) {
                                if (cb.checked) {
                                    var l = gpxLayers[parseInt(cb.getAttribute('data-track-idx'), 10)];
                                    if (l) { group.addLayer(l); }
                                }
                            });
                            map.fitBounds(group.getBounds().pad(0.1));
                        }
                    }
                });
            }
        }());

        /* ── GPX track view (zoom) ── */
        (function () {
            document.querySelectorAll('.st-track-view').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var idx = parseInt(btn.getAttribute('data-track-idx'), 10);
                    var layer = gpxLayers[idx];
                    if (!layer) { return; }
                    var cb = document.querySelector('.st-track-checkbox[data-track-idx="' + idx + '"]');
                    if (cb && !cb.checked) {
                        cb.checked = true;
                        map.addLayer(layer);
                    }
                    try { map.fitBounds(layer.getBounds().pad(0.05)); } catch (e) {}
                });
            });
        }());

        /* ── GPX upload ── */
        {% if canEdit %}
        (function () {
            var btn = document.getElementById('tracks-upload-btn');
            var input = document.getElementById('tracks-upload-input');
            if (!btn || !input) { return; }
            var uploadUrl = '{{ path('uploadGpxAPI', {'travelId': travel.id}) }}';
            var label = document.getElementById('tracks-upload-label');

            function uploadFile(file) {
                if (!file) { return; }
                if (!/\.gpx$/i.test(file.name)) {
                    alert('Please select a .gpx file');
                    return;
                }
                var fd = new FormData();
                fd.append('file', file);
                fd.append('title', file.name.replace(/\.gpx$/i, ''));

                if (label) { label.textContent = 'Uploading…'; }
                btn.style.pointerEvents = 'none';
                btn.style.opacity = '0.7';

                fetch(uploadUrl, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
                    .then(function (res) {
                        if (res.ok) {
                            location.reload();
                        } else {
                            alert((res.data && res.data.error) || 'Upload failed');
                            if (label) { label.textContent = 'Upload GPX track'; }
                            btn.style.pointerEvents = '';
                            btn.style.opacity = '';
                            input.value = '';
                        }
                    })
                    .catch(function (err) {
                        alert('Upload error: ' + (err && err.message ? err.message : err));
                        if (label) { label.textContent = 'Upload GPX track'; }
                        btn.style.pointerEvents = '';
                        btn.style.opacity = '';
                        input.value = '';
                    });
            }

            input.addEventListener('change', function () {
                if (input.files && input.files.length) { uploadFile(input.files[0]); }
            });

            /* Drag & drop on the upload zone */
            ['dragenter', 'dragover'].forEach(function (ev) {
                btn.addEventListener(ev, function (e) {
                    e.preventDefault(); e.stopPropagation();
                    btn.classList.add('is-dragover');
                });
            });
            ['dragleave', 'drop'].forEach(function (ev) {
                btn.addEventListener(ev, function (e) {
                    e.preventDefault(); e.stopPropagation();
                    btn.classList.remove('is-dragover');
                });
            });
            btn.addEventListener('drop', function (e) {
                if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files.length) {
                    uploadFile(e.dataTransfer.files[0]);
                }
            });
        }());

        /* ── GPX delete ── */
        (function () {
            var deleteBaseUrl = '{{ path('deleteGpxAPI', {'gpxId': 999999999}) }}';
            document.querySelectorAll('.st-track-delete').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id = btn.getAttribute('data-track-id');
                    if (!confirm('Delete this GPX track?')) { return; }
                    fetch(deleteBaseUrl.replace('999999999', id), {
                        method: 'DELETE',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(function (r) {
                        if (r.ok) {
                            var layer = gpxLayerById[id];
                            if (layer) { map.removeLayer(layer); }
                            var item = document.getElementById('st-track-' + id);
                            if (item) { item.remove(); }
                        } else {
                            alert('Could not delete the track');
                        }
                    })
                    .catch(function () { alert('Network error'); });
                });
            });
        }());
        {% endif %}

        var printer = L.easyPrint({
            tileLayer: googleRoadMap,
            sizeModes: ['Current', 'A4Landscape', 'A4Portrait'],
            filename: 'myMap',
            exportOnly: true,
            hideControlContainer: true
        }).addTo(map);
    </script>

    {% if app.user and app.user.userId == travel.user.userId %}
    <script>
    (function () {
        var overlay  = document.getElementById('sh-overlay');
        var closeBtn = document.getElementById('sh-modal-close');
        var cancelBtn= document.getElementById('sh-cancel');
        var submitBtn= document.getElementById('sh-submit');
        var input    = document.getElementById('sh-username');
        var feedback = document.getElementById('sh-feedback');
        var openBtn  = document.getElementById('st-share-btn');
        var travelId = openBtn ? openBtn.getAttribute('data-travel-id') : null;
        var shareUrl       = '{{ path('shareTravelAPI',      {'travelId': '__ID__'}) }}'.replace('__ID__', travelId);
        var sharedUsersUrl = '{{ path('getSharedUsersAPI',   {'travelId': '__ID__'}) }}'.replace('__ID__', travelId);
        var unshareBaseUrl = '{{ path('unshareTravelAPI',    {'travelId': '__ID__', 'username': '__USER__'}) }}';

        function unshareUrl(username) {
            return unshareBaseUrl.replace('__ID__', travelId).replace('__USER__', encodeURIComponent(username));
        }

        function loadSharedUsers() {
            var list = document.getElementById('sh-users-list');
            list.innerHTML = '<div class="sh-modal__users-empty">Loading…</div>';
            fetch(sharedUsersUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(function (r) { return r.json(); })
                .then(function (data) { renderSharedUsers(data.users || []); })
                .catch(function () { list.innerHTML = '<div class="sh-modal__users-empty">Could not load.</div>'; });
        }

        function renderSharedUsers(users) {
            var list = document.getElementById('sh-users-list');
            if (!users.length) {
                list.innerHTML = '<div class="sh-modal__users-empty">Not shared with anyone yet.</div>';
                return;
            }
            list.innerHTML = users.map(function (u) {
                var display = escHtml(u.firstName || '') + ' ' + escHtml(u.lastName || '');
                return '<div class="sh-user-row" id="sh-user-' + escHtml(u.username) + '">' +
                    '<span class="sh-user-row__name">' + escHtml(u.username) + '<small>' + display.trim() + '</small></span>' +
                    '<button class="sh-user-revoke" data-username="' + escHtml(u.username) + '" type="button">Revoke</button>' +
                    '</div>';
            }).join('');
            list.querySelectorAll('.sh-user-revoke').forEach(function (btn) {
                btn.addEventListener('click', function () { doRevoke(this.getAttribute('data-username')); });
            });
        }

        function doRevoke(username) {
            fetch(unshareUrl(username), {
                method: 'DELETE',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
            .then(function (result) {
                if (result.ok) {
                    var row = document.getElementById('sh-user-' + username);
                    if (row) { row.remove(); }
                    var list = document.getElementById('sh-users-list');
                    if (!list.querySelector('.sh-user-row')) {
                        list.innerHTML = '<div class="sh-modal__users-empty">Not shared with anyone yet.</div>';
                    }
                } else {
                    showFeedback('error', result.data.error || 'Could not revoke access.');
                }
            })
            .catch(function () { showFeedback('error', 'Network error revoking access.'); });
        }

        function openModal() {
            overlay.classList.add('is-open');
            input.value = '';
            feedback.className = 'sh-modal__feedback';
            feedback.textContent = '';
            loadSharedUsers();
            setTimeout(function () { input.focus(); }, 50);
        }

        function closeModal() {
            overlay.classList.remove('is-open');
        }

        if (openBtn) { openBtn.addEventListener('click', openModal); }
        if (closeBtn) { closeBtn.addEventListener('click', closeModal); }
        if (cancelBtn) { cancelBtn.addEventListener('click', closeModal); }

        overlay.addEventListener('click', function (e) {
            if (e.target === overlay) { closeModal(); }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { closeModal(); }
        });

        input.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { doShare(); }
        });

        submitBtn.addEventListener('click', doShare);

        function doShare() {
            var username = input.value.trim();
            if (!username) {
                showFeedback('error', 'Please enter a username.');
                input.focus();
                return;
            }

            submitBtn.disabled = true;
            submitBtn.textContent = 'Sharing…';

            fetch(shareUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ username: username })
            })
            .then(function (res) {
                return res.text().then(function (text) {
                    var data = null;
                    try { data = JSON.parse(text); } catch (e) {}
                    return { ok: res.ok, status: res.status, data: data, raw: text };
                });
            })
            .then(function (result) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M12 10a2 2 0 0 0-1.6.8L5.9 8.4a2 2 0 0 0 0-1.8l4.5-2.4A2 2 0 1 0 9.6 2.2L5.1 4.6a2 2 0 1 0 0 5.8l4.5 2.4A2 2 0 1 0 12 10z"/></svg> Share';
                if (result.ok) {
                    showFeedback('success', 'Travel shared with <strong>' + escHtml(username) + '</strong>.');
                    input.value = '';
                    loadSharedUsers();
                } else if (result.data && result.data.error) {
                    showFeedback('error', result.data.error);
                } else {
                    showFeedback('error', 'Server error ' + result.status + (result.raw ? ': ' + result.raw.substring(0, 120) : ''));
                }
            })
            .catch(function (err) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M12 10a2 2 0 0 0-1.6.8L5.9 8.4a2 2 0 0 0 0-1.8l4.5-2.4A2 2 0 1 0 9.6 2.2L5.1 4.6a2 2 0 1 0 0 5.8l4.5 2.4A2 2 0 1 0 12 10z"/></svg> Share';
                showFeedback('error', 'Network error: ' + (err && err.message ? err.message : String(err)));
            });
        }

        function showFeedback(type, html) {
            feedback.className = 'sh-modal__feedback is-' + type;
            feedback.innerHTML = html;
        }

        function escHtml(str) {
            return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        var editImageFile = document.getElementById('edit-image-file');
        if (editImageFile) {
            editImageFile.addEventListener('change', function () {
                var preview = document.getElementById('edit-image-preview');
                if (!preview) { return; }
                preview.innerHTML = '';
                var file = this.files[0];
                if (!file) { return; }
                var reader = new FileReader();
                reader.onload = function (e) {
                    var img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.cssText = 'max-height:80px;border-radius:6px;border:1px solid #dde3ea;';
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        }
    }());
    </script>
    {% endif %}

