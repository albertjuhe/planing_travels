{% extends 'base.html.twig' %}

{% block title %} · Forgot Password{% endblock %}

{% block content %}
<div class="container" style="max-width:560px; margin:40px auto;">
    <h1>Forgot your password?</h1>
    <p>Enter your email and we will send you a reset link if the account exists.</p>

    {% for message in app.flashes('notice') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    {{ form_start(form) }}
        <div class="form-group">
            {{ form_label(form.email) }}
            {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'you@example.com'}}) }}
            {{ form_errors(form.email) }}
        </div>

        <button type="submit" class="btn btn-primary">Send reset link</button>
        <a href="{{ path('private_login', {'_locale': app.request.locale}) }}" class="btn btn-link">Back to login</a>
    {{ form_end(form) }}
</div>
{% endblock %}

