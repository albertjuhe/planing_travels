{% extends 'base.html.twig' %}

{% block title %} · Create Account{% endblock %}

{% block content %}
<div class="reg-page">

    {# ── Left panel – branding ── #}
    <div class="reg-side">
        <div class="reg-side__inner">
            <a href="{{ path('homepage') }}" class="reg-brand">
                <span class="reg-brand__icon">✈</span>
                <span class="reg-brand__text">Travel<strong>Share</strong></span>
            </a>
            <h2 class="reg-side__headline">Start your journey today</h2>
            <p class="reg-side__sub">Join thousands of travelers who plan, share and explore the world together.</p>
            <ul class="reg-perks">
                <li>
                    <span class="reg-perks__icon">🗺️</span>
                    <span>Plan trips with interactive maps &amp; GPS routes</span>
                </li>
                <li>
                    <span class="reg-perks__icon">🤝</span>
                    <span>Collaborate and share with fellow travelers</span>
                </li>
                <li>
                    <span class="reg-perks__icon">⭐</span>
                    <span>Discover top-rated adventures from the community</span>
                </li>
                <li>
                    <span class="reg-perks__icon">🆓</span>
                    <span>Completely free, forever</span>
                </li>
            </ul>
        </div>
    </div>

    {# ── Right panel – form ── #}
    <div class="reg-main">
        <div class="reg-card">

            <div class="reg-card__header">
                <h1 class="reg-card__title">Create your account</h1>
                <p class="reg-card__sub">Already have one? <a href="{{ path('private_login') }}">Sign in</a></p>
            </div>

            {# Global form errors #}
            {% if errors|length > 0 %}
                <div class="reg-alert">
                    <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor"><path d="M8 1a7 7 0 1 1 0 14A7 7 0 0 1 8 1zm-.75 3v5h1.5V4h-1.5zm0 6v1.5h1.5V10h-1.5z"/></svg>
                    <div>
                        {% for error in errors %}
                            <div>{{ error.message }}</div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {{ form_start(form, {'attr': {'class': 'reg-form', 'novalidate': 'novalidate'}}) }}

            {# ── Name row ── #}
            <div class="reg-row">
                <div class="reg-field">
                    <label class="reg-label" for="{{ form.firstName.vars.id }}">
                        First name
                    </label>
                    <div class="reg-input-wrap">
                        <svg class="reg-input-icon" viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-5 6a5 5 0 0 1 10 0H3z"/></svg>
                        {{ form_widget(form.firstName, {
                            'attr': {'class': 'reg-input', 'placeholder': 'John'}
                        }) }}
                    </div>
                    {{ form_errors(form.firstName) }}
                </div>
                <div class="reg-field">
                    <label class="reg-label" for="{{ form.lastName.vars.id }}">
                        Last name
                    </label>
                    <div class="reg-input-wrap">
                        <svg class="reg-input-icon" viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-5 6a5 5 0 0 1 10 0H3z"/></svg>
                        {{ form_widget(form.lastName, {
                            'attr': {'class': 'reg-input', 'placeholder': 'Doe'}
                        }) }}
                    </div>
                    {{ form_errors(form.lastName) }}
                </div>
            </div>

            {# ── Username ── #}
            <div class="reg-field">
                <label class="reg-label" for="{{ form.username.vars.id }}">
                    Username
                    <span class="reg-label__hint">Visible to other travelers</span>
                </label>
                <div class="reg-input-wrap">
                    <svg class="reg-input-icon" viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M8 1C4.1 1 1 4.1 1 8s3.1 7 7 7 7-3.1 7-7-3.1-7-7-7zm0 2c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm0 10c-1.8 0-3.3-.9-4.3-2.3C4.9 9.5 6.4 9 8 9s3.1.5 4.3 1.7C11.3 12.1 9.8 13 8 13z"/></svg>
                    {{ form_widget(form.username, {
                        'attr': {'class': 'reg-input', 'placeholder': 'johndoe'}
                    }) }}
                </div>
                {{ form_errors(form.username) }}
            </div>

            {# ── Email ── #}
            <div class="reg-field">
                <label class="reg-label" for="{{ form.email.vars.id }}">
                    Email address
                </label>
                <div class="reg-input-wrap">
                    <svg class="reg-input-icon" viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M1 3h14v10H1V3zm1 1v1.4l6 3.6 6-3.6V4H2zm0 2.8V12h12V5.8L8 9.4 2 5.8z"/></svg>
                    {{ form_widget(form.email, {
                        'attr': {'class': 'reg-input', 'placeholder': 'john@example.com'}
                    }) }}
                </div>
                {{ form_errors(form.email) }}
            </div>

            {# ── Password ── #}
            <div class="reg-field">
                <label class="reg-label" for="{{ form.plainPassword.first.vars.id }}">
                    Password
                </label>
                <div class="reg-input-wrap reg-input-wrap--pw">
                    <svg class="reg-input-icon" viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M8 1a4 4 0 0 1 4 4v1h1v9H3V6h1V5a4 4 0 0 1 4-4zm0 1.5A2.5 2.5 0 0 0 5.5 5v1h5V5A2.5 2.5 0 0 0 8 2.5zM8 9a1 1 0 0 0-1 1v1a1 1 0 0 0 2 0v-1a1 1 0 0 0-1-1z"/></svg>
                    {{ form_widget(form.plainPassword.first, {
                        'attr': {'class': 'reg-input reg-input--pw', 'placeholder': 'Min. 8 characters', 'id': 'reg-pw1'}
                    }) }}
                    <button type="button" class="reg-pw-toggle" data-target="reg-pw1" aria-label="Toggle password">
                        <svg class="reg-eye reg-eye--show" viewBox="0 0 16 16" width="15" height="15" fill="currentColor"><path d="M8 3C4 3 1 8 1 8s3 5 7 5 7-5 7-5-3-5-7-5zm0 8a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>
                        <svg class="reg-eye reg-eye--hide" viewBox="0 0 16 16" width="15" height="15" fill="currentColor" style="display:none"><path d="M2 2l12 12M8 3C4 3 1 8 1 8s.6.9 1.6 1.9M6.1 6.1A3 3 0 0 0 8 11a3 3 0 0 0 2.9-2.1M10.4 10.4C11.9 9.3 13.3 8 15 8c0 0-3-5-7-5-.8 0-1.6.2-2.3.5" stroke="currentColor" stroke-width=".5" fill="none"/></svg>
                    </button>
                </div>
                <div class="reg-strength" id="reg-strength">
                    <div class="reg-strength__bar"><div class="reg-strength__fill" id="reg-strength-fill"></div></div>
                    <span class="reg-strength__label" id="reg-strength-label"></span>
                </div>
                {{ form_errors(form.plainPassword.first) }}
            </div>

            {# ── Confirm password ── #}
            <div class="reg-field">
                <label class="reg-label" for="{{ form.plainPassword.second.vars.id }}">
                    Confirm password
                </label>
                <div class="reg-input-wrap reg-input-wrap--pw">
                    <svg class="reg-input-icon" viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M8 1a4 4 0 0 1 4 4v1h1v9H3V6h1V5a4 4 0 0 1 4-4zm0 1.5A2.5 2.5 0 0 0 5.5 5v1h5V5A2.5 2.5 0 0 0 8 2.5zM8 9a1 1 0 0 0-1 1v1a1 1 0 0 0 2 0v-1a1 1 0 0 0-1-1z"/></svg>
                    {{ form_widget(form.plainPassword.second, {
                        'attr': {'class': 'reg-input reg-input--pw', 'placeholder': 'Repeat your password', 'id': 'reg-pw2'}
                    }) }}
                    <button type="button" class="reg-pw-toggle" data-target="reg-pw2" aria-label="Toggle password">
                        <svg class="reg-eye reg-eye--show" viewBox="0 0 16 16" width="15" height="15" fill="currentColor"><path d="M8 3C4 3 1 8 1 8s3 5 7 5 7-5 7-5-3-5-7-5zm0 8a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>
                        <svg class="reg-eye reg-eye--hide" viewBox="0 0 16 16" width="15" height="15" fill="currentColor" style="display:none"><path d="M2 2l12 12M8 3C4 3 1 8 1 8s.6.9 1.6 1.9M6.1 6.1A3 3 0 0 0 8 11a3 3 0 0 0 2.9-2.1M10.4 10.4C11.9 9.3 13.3 8 15 8c0 0-3-5-7-5-.8 0-1.6.2-2.3.5" stroke="currentColor" stroke-width=".5" fill="none"/></svg>
                    </button>
                </div>
                {{ form_errors(form.plainPassword.second) }}
            </div>

            {# ── Submit ── #}
            <button type="submit" class="reg-submit">
                Create account
                <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </button>

            <p class="reg-terms">
                By creating an account you agree to our
                <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.
            </p>

            {{ form_end(form) }}

        </div>
    </div>

</div>
{% endblock %}

{% block css %}
{{ parent() }}
<style>
/* ─────────────────────────────────────────
   Page layout
───────────────────────────────────────── */
.reg-page {
    display: flex;
    min-height: calc(100vh - 64px);
}

/* ─────────────────────────────────────────
   Left branding panel
───────────────────────────────────────── */
.reg-side {
    width: 420px;
    flex-shrink: 0;
    background: linear-gradient(160deg, #1a2e4a 0%, #2980b9 70%, #5dade2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 48px;
    position: relative;
    overflow: hidden;
}
.reg-side::before {
    content: '';
    position: absolute;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    top: -160px; right: -160px;
}
.reg-side::after {
    content: '';
    position: absolute;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    bottom: -80px; left: -80px;
}
.reg-side__inner { position: relative; z-index: 1; }

.reg-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 40px;
}
.reg-brand:hover { text-decoration: none; }
.reg-brand__icon { font-size: 28px; }
.reg-brand__text { font-size: 24px; color: #fff; letter-spacing: -0.3px; }
.reg-brand__text strong { color: #f39c12; font-weight: 700; }

.reg-side__headline {
    font-size: 28px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 12px;
    line-height: 1.3;
}
.reg-side__sub {
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    margin: 0 0 36px;
    line-height: 1.6;
}

.reg-perks {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
}
.reg-perks li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: rgba(255,255,255,0.88);
    font-size: 14px;
    line-height: 1.5;
}
.reg-perks__icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }

/* ─────────────────────────────────────────
   Right form panel
───────────────────────────────────────── */
.reg-main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f4f6f8;
    padding: 48px 24px;
    overflow-y: auto;
}
.reg-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.09);
    padding: 40px 40px 36px;
    width: 100%;
    max-width: 480px;
}

/* ─────────────────────────────────────────
   Card header
───────────────────────────────────────── */
.reg-card__header { margin-bottom: 28px; }
.reg-card__title {
    font-size: 24px;
    font-weight: 700;
    color: #1a2e4a;
    margin: 0 0 6px;
}
.reg-card__sub {
    font-size: 14px;
    color: #7f8c8d;
    margin: 0;
}
.reg-card__sub a { color: #2980b9; font-weight: 600; }
.reg-card__sub a:hover { color: #1a5276; text-decoration: none; }

/* ─────────────────────────────────────────
   Alert
───────────────────────────────────────── */
.reg-alert {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    background: #fdf2f2;
    border: 1px solid #f5c6cb;
    color: #c0392b;
    border-radius: 8px;
    padding: 12px 14px;
    font-size: 13px;
    margin-bottom: 20px;
    line-height: 1.5;
}

/* ─────────────────────────────────────────
   Form
───────────────────────────────────────── */
.reg-form { display: flex; flex-direction: column; gap: 16px; }

.reg-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}

.reg-field { display: flex; flex-direction: column; gap: 5px; }

.reg-label {
    font-size: 12px;
    font-weight: 700;
    color: #2c3e50;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    margin: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.reg-label__hint {
    font-size: 11px;
    font-weight: 400;
    color: #95a5a6;
    text-transform: none;
    letter-spacing: 0;
}

/* Input wrapper */
.reg-input-wrap {
    position: relative;
}
.reg-input-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: #aab7c4;
    pointer-events: none;
    flex-shrink: 0;
}
.reg-input {
    width: 100%;
    padding: 10px 12px 10px 36px;
    font-size: 14px;
    color: #2c3e50;
    background: #f8f9fa;
    border: 1.5px solid #dde3ea;
    border-radius: 8px;
    outline: none;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
    font-family: inherit;
}
.reg-input:focus {
    border-color: #2980b9;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(41,128,185,0.12);
}
.reg-input::placeholder { color: #b0bec5; }
.reg-input.is-error { border-color: #e74c3c; }
.reg-input.is-error:focus { box-shadow: 0 0 0 3px rgba(231,76,60,0.12); }

/* Password toggle */
.reg-input--pw { padding-right: 40px; }
.reg-input-wrap--pw { position: relative; }
.reg-pw-toggle {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: #aab7c4;
    padding: 2px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
}
.reg-pw-toggle:hover { color: #2c3e50; }

/* Password strength */
.reg-strength {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
}
.reg-strength__bar {
    flex: 1;
    height: 3px;
    background: #eaecef;
    border-radius: 2px;
    overflow: hidden;
}
.reg-strength__fill {
    height: 100%;
    width: 0;
    border-radius: 2px;
    transition: width 0.3s, background 0.3s;
}
.reg-strength__label {
    font-size: 11px;
    font-weight: 600;
    min-width: 40px;
    text-align: right;
}

/* Symfony form errors */
.reg-field ul.form-errors,
.reg-field .form-error {
    list-style: none;
    padding: 0;
    margin: 2px 0 0;
    font-size: 12px;
    color: #e74c3c;
}

/* ─────────────────────────────────────────
   Submit
───────────────────────────────────────── */
.reg-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 12px;
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    background: #f39c12;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    margin-top: 4px;
    font-family: inherit;
}
.reg-submit:hover { background: #e67e22; }
.reg-submit:active { transform: scale(0.99); }

/* ─────────────────────────────────────────
   Terms
───────────────────────────────────────── */
.reg-terms {
    text-align: center;
    font-size: 12px;
    color: #95a5a6;
    margin: 14px 0 0;
    line-height: 1.5;
}
.reg-terms a { color: #7f8c8d; }
.reg-terms a:hover { color: #2c3e50; text-decoration: none; }

/* ─────────────────────────────────────────
   Responsive
───────────────────────────────────────── */
@media (max-width: 900px) {
    .reg-side { display: none; }
    .reg-main { padding: 40px 16px; }
}
@media (max-width: 520px) {
    .reg-card { padding: 32px 20px 28px; }
    .reg-row  { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block javascript %}
{{ parent() }}
<script>
(function () {

    /* ── Password visibility toggles ── */
    document.querySelectorAll('.reg-pw-toggle').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var input  = document.getElementById(btn.dataset.target);
            var isText = input.type === 'text';
            input.type = isText ? 'password' : 'text';
            btn.querySelector('.reg-eye--show').style.display = isText ? ''     : 'none';
            btn.querySelector('.reg-eye--hide').style.display = isText ? 'none' : '';
        });
    });

    /* ── Password strength meter ── */
    var pw1    = document.getElementById('reg-pw1');
    var fill   = document.getElementById('reg-strength-fill');
    var label  = document.getElementById('reg-strength-label');

    if (pw1 && fill && label) {
        pw1.addEventListener('input', function () {
            var v = pw1.value;
            var score = 0;
            if (v.length >= 8)                    score++;
            if (v.length >= 12)                   score++;
            if (/[A-Z]/.test(v))                  score++;
            if (/[0-9]/.test(v))                  score++;
            if (/[^A-Za-z0-9]/.test(v))           score++;

            var levels = [
                { w: '0%',   bg: 'transparent', txt: '' },
                { w: '25%',  bg: '#e74c3c',     txt: 'Weak' },
                { w: '50%',  bg: '#e67e22',     txt: 'Fair' },
                { w: '75%',  bg: '#f39c12',     txt: 'Good' },
                { w: '90%',  bg: '#27ae60',     txt: 'Strong' },
                { w: '100%', bg: '#1e8449',     txt: 'Great!' }
            ];
            var lvl = levels[Math.min(score, 5)];
            fill.style.width      = v.length ? lvl.w  : '0%';
            fill.style.background = lvl.bg;
            label.textContent     = v.length ? lvl.txt : '';
            label.style.color     = lvl.bg;
        });
    }

    /* ── Confirm password match indicator ── */
    var pw2 = document.getElementById('reg-pw2');
    if (pw1 && pw2) {
        function checkMatch() {
            if (!pw2.value) { pw2.classList.remove('is-error'); return; }
            pw2.classList.toggle('is-error', pw1.value !== pw2.value);
        }
        pw1.addEventListener('input', checkMatch);
        pw2.addEventListener('input', checkMatch);
    }

}());
</script>
{% endblock %}
