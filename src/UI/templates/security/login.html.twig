{% extends 'base.html.twig' %}

{% block title %} · Sign In{% endblock %}

{% block content %}
<div class="login-page">
    <div class="login-card">

        <!-- Logo / Brand -->
        <div class="login-brand">
            <a href="{{ path('homepage') }}" class="login-brand__link">
                <span class="login-brand__icon">✈</span>
                <span class="login-brand__text">Travel<strong>Share</strong></span>
            </a>
        </div>

        <h1 class="login-title">Welcome back</h1>
        <p class="login-subtitle">Sign in to continue your adventures</p>

        {% if error %}
            <div class="login-alert">
                <span class="glyphicon glyphicon-exclamation-sign"></span>
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form class="login-form" action="{{ path('private_login') }}" method="post">

            <div class="login-field">
                <label for="username" class="login-label">Username</label>
                <div class="login-input-wrap">
                    <span class="login-input-icon glyphicon glyphicon-user"></span>
                    <input
                        type="text"
                        class="login-input"
                        id="username"
                        name="_username"
                        value="{{ last_username }}"
                        placeholder="Your username"
                        required
                        autofocus
                    >
                </div>
            </div>

            <div class="login-field">
                <label for="password" class="login-label">
                    Password
                    <a href="#" class="login-forgot">Forgot password?</a>
                </label>
                <div class="login-input-wrap">
                    <span class="login-input-icon glyphicon glyphicon-lock"></span>
                    <input
                        type="password"
                        class="login-input"
                        id="password"
                        name="_password"
                        placeholder="Your password"
                        required
                    >
                </div>
            </div>

            <div class="login-remember">
                <label class="login-checkbox">
                    <input type="checkbox" id="remember_me" name="_remember_me" checked>
                    <span class="login-checkbox__mark"></span>
                    Keep me signed in
                </label>
            </div>

            <button class="login-submit" type="submit">Sign In</button>

        </form>

        <p class="login-register">
            Don't have an account?
            <a href="{{ path('private_register') }}">Create one for free</a>
        </p>

    </div>
</div>
{% endblock %}

{% block css %}
    {{ parent() }}
    <style>
        /* ── Page layout ── */
        .login-page {
            min-height: calc(100vh - 64px);
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1a2e4a 0%, #2980b9 60%, #6dd5fa 100%);
            padding: 40px 16px;
        }

        /* ── Card ── */
        .login-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
            padding: 48px 40px 40px;
            width: 100%;
            max-width: 420px;
        }

        /* ── Brand ── */
        .login-brand {
            text-align: center;
            margin-bottom: 28px;
        }
        .login-brand__link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .login-brand__link:hover { text-decoration: none; }
        .login-brand__icon { font-size: 26px; line-height: 1; }
        .login-brand__text {
            font-size: 22px;
            color: #1a2e4a;
            letter-spacing: -0.3px;
        }
        .login-brand__text strong { color: #f39c12; font-weight: 700; }

        /* ── Headings ── */
        .login-title {
            font-size: 26px;
            font-weight: 700;
            color: #1a2e4a;
            text-align: center;
            margin: 0 0 6px;
        }
        .login-subtitle {
            font-size: 14px;
            color: #7f8c8d;
            text-align: center;
            margin: 0 0 28px;
        }

        /* ── Error alert ── */
        .login-alert {
            background: #fdf2f2;
            border: 1px solid #f5c6cb;
            color: #c0392b;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 14px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* ── Fields ── */
        .login-form { display: flex; flex-direction: column; gap: 18px; }
        .login-field { display: flex; flex-direction: column; gap: 6px; }
        .login-label {
            font-size: 13px;
            font-weight: 600;
            color: #2c3e50;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 0;
        }
        .login-forgot {
            font-size: 12px;
            font-weight: 400;
            color: #2980b9;
        }
        .login-forgot:hover { color: #1a5276; text-decoration: none; }

        .login-input-wrap {
            position: relative;
        }
        .login-input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #aab7c4;
            font-size: 14px;
            pointer-events: none;
        }
        .login-input {
            width: 100%;
            padding: 11px 14px 11px 40px;
            font-size: 14px;
            color: #2c3e50;
            background: #f8f9fa;
            border: 1.5px solid #dde3ea;
            border-radius: 8px;
            outline: none;
            transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
            box-sizing: border-box;
        }
        .login-input:focus {
            border-color: #2980b9;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(41, 128, 185, 0.12);
        }
        .login-input::placeholder { color: #b0bec5; }

        /* ── Remember me ── */
        .login-remember { margin-top: -4px; }
        .login-checkbox {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #555;
            cursor: pointer;
            margin: 0;
            font-weight: 400;
        }
        .login-checkbox input[type="checkbox"] { display: none; }
        .login-checkbox__mark {
            width: 16px;
            height: 16px;
            border: 1.5px solid #aab7c4;
            border-radius: 4px;
            background: #f8f9fa;
            flex-shrink: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: background 0.15s, border-color 0.15s;
        }
        .login-checkbox input:checked + .login-checkbox__mark {
            background: #2980b9;
            border-color: #2980b9;
        }
        .login-checkbox input:checked + .login-checkbox__mark::after {
            content: '';
            display: block;
            width: 4px;
            height: 7px;
            border: 2px solid #fff;
            border-top: none;
            border-left: none;
            transform: rotate(45deg) translateY(-1px);
        }

        /* ── Submit ── */
        .login-submit {
            width: 100%;
            padding: 12px;
            font-size: 15px;
            font-weight: 600;
            color: #fff;
            background: #f39c12;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s, transform 0.1s;
            margin-top: 4px;
        }
        .login-submit:hover { background: #e67e22; }
        .login-submit:active { transform: scale(0.99); }

        /* ── Register link ── */
        .login-register {
            text-align: center;
            font-size: 13px;
            color: #7f8c8d;
            margin: 20px 0 0;
        }
        .login-register a { color: #2980b9; font-weight: 600; }
        .login-register a:hover { color: #1a5276; text-decoration: none; }

        /* ── Responsive ── */
        @media (max-width: 480px) {
            .login-card { padding: 36px 24px 32px; }
            .login-title { font-size: 22px; }
        }
    </style>
{% endblock %}
