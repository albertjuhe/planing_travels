{% extends 'base.html.twig' %}

{% block title %} · Sign In{% endblock %}

{% block content %}
<div class="login-page">

    <!-- Decorative background blobs -->
    <div class="login-bg-blob login-bg-blob--1" aria-hidden="true"></div>
    <div class="login-bg-blob login-bg-blob--2" aria-hidden="true"></div>

    <div class="login-card">

        <!-- Top accent bar -->
        <div class="login-card__accent" aria-hidden="true"></div>

        <!-- Logo / Brand -->
        <div class="login-brand">
            <a href="{{ path('homepage') }}" class="login-brand__link">
                <span class="login-brand__icon">✈</span>
                <span class="login-brand__text">Travel<strong>Share</strong></span>
            </a>
        </div>

        <h1 class="login-title">Welcome back</h1>
        <p class="login-subtitle">Sign in to continue your adventures</p>

        {% if error %}
            <div class="login-alert" role="alert">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 1a7 7 0 1 1 0 14A7 7 0 0 1 8 1zm-.75 3.5v4.5h1.5V4.5h-1.5zm0 6v1.5h1.5v-1.5h-1.5z"/></svg>
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form class="login-form" action="{{ path('private_login') }}" method="post" novalidate>

            <div class="login-field">
                <label for="username" class="login-label">Username</label>
                <div class="login-input-wrap">
                    <svg class="login-input-icon" viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm5 5a5 5 0 0 0-10 0h10z"/></svg>
                    <input
                        type="text"
                        class="login-input"
                        id="username"
                        name="_username"
                        value="{{ last_username }}"
                        placeholder="Your username"
                        required
                        autofocus
                        autocomplete="username"
                    >
                </div>
            </div>

            <div class="login-field">
                <label for="password" class="login-label">
                    Password
                </label>
                <div class="login-input-wrap">
                    <svg class="login-input-icon" viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M11 6V5a3 3 0 0 0-6 0v1H3v9h10V6h-2zm-5-1a2 2 0 0 1 4 0v1H6V5zm2 7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/></svg>
                    <input
                        type="password"
                        class="login-input login-input--password"
                        id="password"
                        name="_password"
                        placeholder="Your password"
                        required
                        autocomplete="current-password"
                    >
                    <button type="button" class="login-eye" id="login-eye" aria-label="Show password" tabindex="-1">
                        <svg class="login-eye__show" viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M8 3C4.5 3 1.5 6 1 8c.5 2 3.5 5 7 5s6.5-3 7-5c-.5-2-3.5-5-7-5zm0 8a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0-5a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/></svg>
                        <svg class="login-eye__hide" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" style="display:none"><path d="M2 2l12 12M8 3C4.5 3 1.5 6 1 8c.3 1.2 1.2 2.5 2.5 3.5M6 5.5A3 3 0 0 1 11 9M10.5 10.5A3 3 0 0 1 5 7M12.5 11.5C13.8 10.5 14.7 9.2 15 8c-.5-2-3.5-5-7-5" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>
                    </button>
                </div>
            </div>

            <div class="login-row">
                <label class="login-checkbox">
                    <input type="checkbox" id="remember_me" name="_remember_me" checked>
                    <span class="login-checkbox__mark"></span>
                    Keep me signed in
                </label>
                <a href="{{ path('forgot_password', {'_locale': app.request.locale|default('en')}) }}" class="login-forgot">Forgot password?</a>
            </div>

            <button class="login-submit" type="submit">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 1a7 7 0 1 1 0 14A7 7 0 0 1 8 1zm3.3 4.3L7 9.6 4.7 7.3l-1 1L7 11.6l5.3-5.3-1-1z"/></svg>
                Sign In
            </button>

        </form>

        <div class="login-divider"><span>New here?</span></div>

        <a href="{{ path('private_register') }}" class="login-register-btn">Create a free account</a>

    </div>
</div>
{% endblock %}

{% block css %}
    {{ parent() }}
    <style>
        /* ── Page layout ── */
        .login-page {
            position: relative;
            min-height: calc(100vh - 64px);
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(150deg, #0f1f36 0%, #1a3a5c 40%, #1e6fa8 80%, #4aa8d8 100%);
            padding: 40px 16px;
            overflow: hidden;
        }

        /* ── Decorative blobs ── */
        .login-bg-blob {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
            opacity: 0.12;
        }
        .login-bg-blob--1 {
            width: 520px;
            height: 520px;
            background: radial-gradient(circle, #6dd5fa, transparent 70%);
            top: -160px;
            right: -120px;
        }
        .login-bg-blob--2 {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, #f39c12, transparent 70%);
            bottom: -120px;
            left: -100px;
        }

        /* ── Card ── */
        .login-card {
            position: relative;
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35), 0 4px 16px rgba(0,0,0,0.15);
            padding: 0 0 40px;
            width: 100%;
            max-width: 430px;
            animation: login-card-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
        }
        @keyframes login-card-in {
            from { opacity: 0; transform: translateY(28px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }

        /* Top accent bar */
        .login-card__accent {
            height: 5px;
            border-radius: 20px 20px 0 0;
            background: linear-gradient(90deg, #1a3a5c, #2980b9 50%, #f39c12);
        }

        /* Inner padding wrapper */
        .login-brand,
        .login-title,
        .login-subtitle,
        .login-alert,
        .login-form,
        .login-divider,
        .login-register-btn {
            padding-left: 40px;
            padding-right: 40px;
        }

        /* ── Brand ── */
        .login-brand {
            text-align: center;
            padding-top: 36px;
            margin-bottom: 24px;
        }
        .login-brand__link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .login-brand__link:hover { text-decoration: none; }
        .login-brand__icon {
            font-size: 28px;
            line-height: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, #1a3a5c, #2980b9);
            border-radius: 12px;
            color: #fff;
        }
        .login-brand__text {
            font-size: 22px;
            color: #1a2e4a;
            letter-spacing: -0.3px;
        }
        .login-brand__text strong { color: #f39c12; font-weight: 700; }

        /* ── Headings ── */
        .login-title {
            font-size: 26px;
            font-weight: 700;
            color: #1a2e4a;
            text-align: center;
            margin: 0 0 6px;
        }
        .login-subtitle {
            font-size: 14px;
            color: #7f8c8d;
            text-align: center;
            margin: 0 0 28px;
        }

        /* ── Error alert ── */
        .login-alert {
            background: #fdf2f2;
            border: 1px solid #f5c6cb;
            color: #c0392b;
            border-radius: 10px;
            padding: 11px 14px;
            font-size: 14px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 9px;
        }

        /* ── Fields ── */
        .login-form { display: flex; flex-direction: column; gap: 18px; }
        .login-field { display: flex; flex-direction: column; gap: 6px; }
        .login-label {
            font-size: 13px;
            font-weight: 600;
            color: #2c3e50;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 0;
        }

        .login-input-wrap { position: relative; }
        .login-input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #aab7c4;
            pointer-events: none;
        }
        .login-input {
            width: 100%;
            padding: 11px 14px 11px 42px;
            font-size: 14px;
            color: #2c3e50;
            background: #f8f9fa;
            border: 1.5px solid #dde3ea;
            border-radius: 10px;
            outline: none;
            transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
            box-sizing: border-box;
        }
        .login-input--password { padding-right: 44px; }
        .login-input:focus {
            border-color: #2980b9;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(41, 128, 185, 0.13);
        }
        .login-input::placeholder { color: #b0bec5; }

        /* Password eye toggle */
        .login-eye {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            padding: 4px;
            cursor: pointer;
            color: #aab7c4;
            display: flex;
            align-items: center;
            transition: color 0.15s;
        }
        .login-eye:hover { color: #2980b9; }

        /* ── Remember + forgot row ── */
        .login-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            margin-top: -4px;
        }
        .login-forgot {
            font-size: 12px;
            font-weight: 500;
            color: #2980b9;
            white-space: nowrap;
        }
        .login-forgot:hover { color: #1a5276; text-decoration: none; }

        .login-checkbox {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #555;
            cursor: pointer;
            margin: 0;
            font-weight: 400;
        }
        .login-checkbox input[type="checkbox"] { display: none; }
        .login-checkbox__mark {
            width: 17px;
            height: 17px;
            border: 1.5px solid #aab7c4;
            border-radius: 5px;
            background: #f8f9fa;
            flex-shrink: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: background 0.15s, border-color 0.15s;
        }
        .login-checkbox input:checked + .login-checkbox__mark {
            background: #2980b9;
            border-color: #2980b9;
        }
        .login-checkbox input:checked + .login-checkbox__mark::after {
            content: '';
            display: block;
            width: 4px;
            height: 7px;
            border: 2px solid #fff;
            border-top: none;
            border-left: none;
            transform: rotate(45deg) translateY(-1px);
        }

        /* ── Submit ── */
        .login-submit {
            width: 100%;
            padding: 13px;
            font-size: 15px;
            font-weight: 600;
            color: #fff;
            background: linear-gradient(135deg, #1e6fa8, #2980b9);
            border: none;
            border-radius: 10px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: filter 0.2s, transform 0.1s, box-shadow 0.2s;
            box-shadow: 0 4px 14px rgba(41, 128, 185, 0.35);
            margin-top: 4px;
        }
        .login-submit:hover {
            filter: brightness(1.08);
            box-shadow: 0 6px 20px rgba(41, 128, 185, 0.45);
        }
        .login-submit:active { transform: scale(0.99); }

        /* ── Divider ── */
        .login-divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 28px 0 16px;
            color: #b0bec5;
            font-size: 12px;
        }
        .login-divider::before,
        .login-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #eaecef;
        }

        /* ── Register button ── */
        .login-register-btn {
            display: block;
            text-align: center;
            padding: 11px;
            font-size: 14px;
            font-weight: 600;
            color: #2980b9;
            background: #f0f7fd;
            border: 1.5px solid #c2dff0;
            border-radius: 10px;
            text-decoration: none;
            transition: background 0.15s, border-color 0.15s, color 0.15s;
        }
        .login-register-btn:hover {
            background: #daeef9;
            border-color: #2980b9;
            color: #1a5276;
            text-decoration: none;
        }

        /* ── Responsive ── */
        @media (max-width: 480px) {
            .login-brand,
            .login-title,
            .login-subtitle,
            .login-alert,
            .login-form,
            .login-divider,
            .login-register-btn { padding-left: 24px; padding-right: 24px; }
            .login-card { padding-bottom: 32px; }
            .login-title { font-size: 22px; }
        }
    </style>
{% endblock %}

{% block javascript %}
{{ parent() }}
<script>
(function () {
    var eyeBtn  = document.getElementById('login-eye');
    var pwdInput = document.getElementById('password');
    if (!eyeBtn || !pwdInput) return;
    var iconShow = eyeBtn.querySelector('.login-eye__show');
    var iconHide = eyeBtn.querySelector('.login-eye__hide');
    eyeBtn.addEventListener('click', function () {
        var isPassword = pwdInput.type === 'password';
        pwdInput.type = isPassword ? 'text' : 'password';
        iconShow.style.display = isPassword ? 'none' : '';
        iconHide.style.display = isPassword ? '' : 'none';
        eyeBtn.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
    });
}());
</script>
{% endblock %}
