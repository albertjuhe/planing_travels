    <div class="container">
        <div class="ts-navbar__inner">

            <!-- Brand -->
            <a class="ts-navbar__brand" href="{{ path('homepage') }}">
                <span class="ts-navbar__brand-icon">✈</span>
                <span class="ts-navbar__brand-text">Juhe<strong>Travel</strong></span>
            </a>

            <!-- Hamburger (mobile) -->
            <button class="ts-navbar__toggle" id="ts-navbar-toggle" aria-label="Toggle navigation" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <!-- Nav links -->
            <div class="ts-navbar__collapse" id="ts-navbar-collapse">
                <ul class="ts-navbar__nav">
                    <li class="ts-navbar__item">
                        <a class="ts-navbar__link" href="{{ path('homepage') }}">Home</a>
