                                <span class="ts-navbar__username">{{ app.user.username }}</span>
                                <svg class="ts-navbar__chevron" viewBox="0 0 10 6" width="10" height="6"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
                            </button>
                            <ul class="ts-navbar__dropdown" id="ts-user-dropdown" role="menu">
