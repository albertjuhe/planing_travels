<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Domain\Budget\Model\ExpenseShare" table="expense_share">
        <indexes>
            <index name="share_expense_idx" columns="expense_id"/>
            <index name="share_debtor_idx" columns="debtor_user_id"/>
        </indexes>
        <id name="id" type="integer">
            <generator strategy="IDENTITY"/>
        </id>
        <field name="amount"                 type="decimal" precision="10" scale="2"        nullable="false"/>
        <field name="amountInTravelCurrency" type="decimal" precision="10" scale="2" column="amount_in_travel_currency" nullable="false"/>
        <field name="settledAt"              type="datetime" column="settled_at"            nullable="true"/>
        <many-to-one field="expense" target-entity="App\Domain\Budget\Model\TravelExpense" inversed-by="shares" fetch="LAZY">
            <join-column name="expense_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>
        <many-to-one field="debtor" target-entity="App\Domain\User\Model\User" fetch="LAZY">
            <join-column name="debtor_user_id" referenced-column-name="id" nullable="false"/>
        </many-to-one>
    </entity>

</doctrine-mapping>
