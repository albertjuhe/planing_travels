<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Domain\Images\Model\Images" table="images">
        <id name="id" type="integer">
            <generator strategy="IDENTITY"/>
        </id>
        <field name="original"  type="string"   length="255" nullable="false"/>
        <field name="filename"  type="string"   length="255" nullable="false"/>
        <field name="createdAt" type="datetime"              nullable="false"/>
        <field name="updatedAt" type="datetime"              nullable="false"/>
        <field name="isClonedReference" type="boolean" column="is_cloned_reference" nullable="false"/>
        <field name="originalImageId" type="integer" column="original_image_id" nullable="true"/>
        <many-to-one field="location" target-entity="App\Domain\Location\Model\Location" inversed-by="images" fetch="LAZY">
            <join-column name="location_id" referenced-column-name="id"/>
        </many-to-one>
        <lifecycle-callbacks/>
    </entity>

</doctrine-mapping>
